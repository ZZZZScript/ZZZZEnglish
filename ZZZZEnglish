local toggles = {}

local function criarToggle(icone, texto, y)
    local card = Instance.new("Frame")
    card.Size = UDim2.new(1, 0, 0, 36)
    card.Position = UDim2.new(0, 0, 0, y)
    card.BackgroundColor3 = corCard
    card.Parent = scroll
    Instance.new("UICorner", card).CornerRadius = UDim.new(0, 6)
    
    local iconeLab = Instance.new("TextLabel")
    iconeLab.Size = UDim2.new(0, 28, 0, 28)
    iconeLab.Position = UDim2.new(0, 6, 0.5, -14)
    iconeLab.Text = icone
    iconeLab.Font = Enum.Font.Gotham
    iconeLab.TextSize = 16
    iconeLab.TextColor3 = corToggleOn
    iconeLab.BackgroundTransparency = 1
    iconeLab.Parent = card
    
    local textoLab = Instance.new("TextLabel")
    textoLab.Size = UDim2.new(0, 100, 0, 20)
    textoLab.Position = UDim2.new(0, 38, 0.5, -10)
    textoLab.Text = texto
    textoLab.Font = Enum.Font.GothamBold
    textoLab.TextSize = 10
    textoLab.TextColor3 = corTextoBranco
    textoLab.BackgroundTransparency = 1
    textoLab.TextXAlignment = Enum.TextXAlignment.Left
    textoLab.Parent = card
    
    local toggle = Instance.new("TextButton")
    toggle.Size = UDim2.new(0, 38, 0, 20)
    toggle.Position = UDim2.new(1, -45, 0.5, -10)
    toggle.Text = ""
    toggle.BackgroundColor3 = corToggleOff
    toggle.Parent = card
    Instance.new("UICorner", toggle).CornerRadius = UDim.new(1, 0)
    
    local bola = Instance.new("Frame")
    bola.Size = UDim2.new(0, 16, 0, 16)
    bola.Position = UDim2.new(0, 2, 0.5, -8)
    bola.BackgroundColor3 = corBolinha
    bola.Parent = toggle
    Instance.new("UICorner", bola).CornerRadius = UDim.new(1, 0)
    
    local ativo = false
    local callback = nil
    
    toggle.MouseButton1Click:Connect(function()
        ativo = not ativo
        if ativo then
            toggle.BackgroundColor3 = corToggleOn
            bola.Position = UDim2.new(1, -18, 0.5, -8)
        else
            toggle.BackgroundColor3 = corToggleOff
            bola.Position = UDim2.new(0, 2, 0.5, -8)
        end
        if callback then callback(ativo) end
    end)
    
    return {
        onToggle = function(cb) callback = cb end,
        getAtivo = function() return ativo end
    }
end

