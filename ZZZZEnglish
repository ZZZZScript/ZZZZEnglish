-- Auto Attack
RunService.RenderStepped:Connect(function()
    if getAutoAttack() and player.Character then
        local hrp = player.Character:FindFirstChild("HumanoidRootPart")
        if hrp then
            local maisPerto, dist = nil, math.huge
            for _, v in pairs(Players:GetPlayers()) do
                if v ~= player and v.Character and v.Character:FindFirstChild("HumanoidRootPart") then
                    local d = (v.Character.HumanoidRootPart.Position - hrp.Position).Magnitude
                    if d < dist then
                        dist, maisPerto = d, v
                    end
                end
            end
            if maisPerto and dist < 20 then
                hrp.Velocity = (maisPerto.Character.HumanoidRootPart.Position - hrp.Position).Unit * 60
                if dist < 8 then
                    local tool = player.Character:FindFirstChildOfClass("Tool")
                    if tool then tool:Activate() end
                end
            end
        end
    end
end)

-- Auto Hit
RunService.RenderStepped:Connect(function()
    if getHit() and player.Character then
        local hum = player.Character:FindFirstChildOfClass("Humanoid")
        local hrp = player.Character:FindFirstChild("HumanoidRootPart")
        if hum and hrp then
            local maisPerto, dist = nil, math.huge
            for _, v in pairs(Players:GetPlayers()) do
                if v ~= player and v.Character and v.Character:FindFirstChild("HumanoidRootPart") then
                    local d = (v.Character.HumanoidRootPart.Position - hrp.Position).Magnitude
                    if d < dist and d < 10 then
                        dist, maisPerto = d, v
                    end
                end
            end
            if maisPerto then
                hum:MoveTo(maisPerto.Character.HumanoidRootPart.Position)
                local tool = player.Character:FindFirstChildOfClass("Tool")
                if tool then tool:Activate() end
            end
        end
    end
end)

