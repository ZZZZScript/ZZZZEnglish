        abaCredits.TextColor3 = corTextoClaro
        scroll.Visible = true
        creditsScroll.Visible = false
    else
        abaCredits.BackgroundColor3 = corToggleOn
        abaCredits.TextColor3 = corTextoBranco
        abaMain.BackgroundColor3 = corCard
        abaMain.TextColor3 = corTextoClaro
        scroll.Visible = false
        creditsScroll.Visible = true
    end
end

