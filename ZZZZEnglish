-- SCRIPT DE DIAGNÓSTICO
local Players = game:GetService("Players")
local HttpService = game:GetService("HttpService")

local player = Players.LocalPlayer
local API_URL = "https://discord-node-bot--joaolmadureira2.replit.app"

print("========== DIAGNÓSTICO ==========")
print("Seu ID: " .. player.UserId)
print("URL: " .. API_URL .. "/check?id=" .. player.UserId)

-- Teste 1: Verificar se o servidor responde
local success, response = pcall(function()
    return game:HttpGet(API_URL)
end)

print("\n[TESTE 1] Servidor online?")
if success then
    print("✅ Servidor respondeu!")
    print("Resposta: " .. string.sub(response, 1, 100))
else
    print("❌ Servidor não respondeu!")
    print("Erro: " .. tostring(response))
end

-- Teste 2: Verificar acesso
print("\n[TESTE 2] Verificando acesso...")
local success2, response2 = pcall(function()
    return game:HttpGet(API_URL .. "/check?id=" .. player.UserId)
end)

if success2 then
    print("Resposta bruta: " .. response2)
    
    local successJSON, data = pcall(function()
        return HttpService:JSONDecode(response2)
    end)
    
    if successJSON then
        print("✅ JSON decodificado!")
        print("Access: " .. tostring(data.access))
        print("ID retornado: " .. tostring(data.id))
        
        if data.access == true then
            print("\n🎉 SEU ACESSO ESTÁ LIBERADO!")
        else
            print("\n❌ SEU ACESSO NÃO ESTÁ LIBERADO!")
            print("Use !liberar " .. player.UserId .. " no Discord")
        end
    else
        print("❌ Não foi JSON. Resposta: " .. response2)
    end
else
    print("❌ Erro na requisição: " .. tostring(response2))
end

print("\n========== FIM ==========")
