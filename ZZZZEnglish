-- DRAG DO ÍCONE
local iconDrag = false
local iconMousePos, iconFramePos

iconButton.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 then
        iconDrag = true
        iconMousePos = input.Position
        iconFramePos = iconButton.Position
    end
end)

iconButton.InputEnded:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 then
        iconDrag = false
    end
end)

UserInputService.InputChanged:Connect(function(input)
    if iconDrag and input.UserInputType == Enum.UserInputType.MouseMovement then
        local delta = input.Position - iconMousePos
        iconButton.Position = UDim2.new(iconFramePos.X.Scale, iconFramePos.X.Offset + delta.X, iconFramePos.Y.Scale, iconFramePos.Y.Offset + delta.Y)
    end
end)

