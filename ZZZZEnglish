-- Super Jump
local function setSuperJump()
    if player.Character then
        local hum = player.Character:FindFirstChildOfClass("Humanoid")
        if hum then
            hum.JumpPower = active.superJump and 120 or 50
        end
    end
end

player.CharacterAdded:Connect(function()
    task.wait(0.2)
    setSuperJump()
    setSpeed()
end)

RunService.RenderStepped:Connect(setSuperJump)

-- Auto Attack
local jumpCD = false
RunService.RenderStepped:Connect(function()
    if active.auto and player.Character then
        local hrp = player.Character:FindFirstChild("HumanoidRootPart")
        if hrp then
            local closest, dist = nil, math.huge
            for _, v in pairs(Players:GetPlayers()) do
                if v ~= player and v.Character and v.Character:FindFirstChild("HumanoidRootPart") then
                    local d = (v.Character.HumanoidRootPart.Position - hrp.Position).Magnitude
                    if d < dist then dist, closest = d, v end
                end
            end
            if closest and dist < 20 then
                hrp.Velocity = (closest.Character.HumanoidRootPart.Position - hrp.Position).Unit * 60
                if dist < 8 then
                    local tool = player.Character:FindFirstChildOfClass("Tool")
                    if tool then tool:Activate() end
                end
            end
        end
    end
end)

-- Auto Hit
RunService.RenderStepped:Connect(function()
    if active.hit and player.Character then
        local hum = player.Character:FindFirstChildOfClass("Humanoid")
        local hrp = player.Character:FindFirstChild("HumanoidRootPart")
        if hum and hrp then
            local closest, dist = nil, math.huge
            for _, v in pairs(Players:GetPlayers()) do
                if v ~= player and v.Character and v.Character:FindFirstChild("HumanoidRootPart") then
                    local d = (v.Character.HumanoidRootPart.Position - hrp.Position).Magnitude
                    if d < dist and d < 10 then dist, closest = d, v end
                end
            end
            if closest then
                hum:MoveTo(closest.Character.HumanoidRootPart.Position)
                local tool = player.Character:FindFirstChildOfClass("Tool")
                if tool then tool:Activate() end
            end
        end
    end
end)

-- Speed
local speedActive = false
local function setSpeed()
    if player.Character then
        local hum = player.Character:FindFirstChildOfClass("Humanoid")
        if hum then
            hum.WalkSpeed = speedActive and 50 or 27
        end
    end
end

spawn(function()
    while true do
        task.wait(0.1)
        if speedActive ~= active.speed then
            speedActive = active.speed
            setSpeed()
        end
        setSpeed()
    end
end)

-- Spin Bot
RunService.RenderStepped:Connect(function()
    if active.spin and player.Character then
        local hrp = player.Character:FindFirstChild("HumanoidRootPart")
        if hrp then
            hrp.CFrame = hrp.CFrame * CFrame.Angles(0, math.rad(25), 0)
        end
