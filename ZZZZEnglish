-- Super Jump
local function setJump()
    if player.Character then
        local hum = player.Character:FindFirstChildOfClass("Humanoid")
        if hum then hum.JumpPower = pvpAtivo.superJump and 120 or 50 end
    end
end

player.CharacterAdded:Connect(function() task.wait(0.2); setJump() end)
RunService.RenderStepped:Connect(setJump)

-- Auto Attack
RunService.RenderStepped:Connect(function()
    if pvpAtivo.auto and player.Character then
        local root = player.Character:FindFirstChild("HumanoidRootPart")
        if root then
            local closest, best = nil, math.huge
            for _, v in pairs(Players:GetPlayers()) do
                if v ~= player and v.Character and v.Character:FindFirstChild("HumanoidRootPart") then
                    local d = (v.Character.HumanoidRootPart.Position - root.Position).Magnitude
                    if d < best then best, closest = d, v end
                end
            end
            if closest and best < 20 then
                root.Velocity = (closest.Character.HumanoidRootPart.Position - root.Position).Unit * 60
                if best < 8 then
                    local tool = player.Character:FindFirstChildOfClass("Tool")
                    if tool then tool:Activate() end
                end
            end
        end
    end
end)

-- Auto Hit
RunService.RenderStepped:Connect(function()
    if pvpAtivo.hit and player.Character then
        local hum = player.Character:FindFirstChildOfClass("Humanoid")
        local root = player.Character:FindFirstChild("HumanoidRootPart")
        if hum and root then
            local closest, best = nil, math.huge
            for _, v in pairs(Players:GetPlayers()) do
                if v ~= player and v.Character and v.Character:FindFirstChild("HumanoidRootPart") then
                    local d = (v.Character.HumanoidRootPart.Position - root.Position).Magnitude
                    if d < best and d < 10 then best, closest = d, v end
                end
            end
            if closest then
                hum:MoveTo(closest.Character.HumanoidRootPart.Position)
                local tool = player.Character:FindFirstChildOfClass("Tool")
                if tool then tool:Activate() end
            end
        end
    end
end)

-- Spin Bot
RunService.RenderStepped:Connect(function()
    if pvpAtivo.spin and player.Character then
        local root = player.Character:FindFirstChild("HumanoidRootPart")
        if root then root.CFrame = root.CFrame * CFrame.Angles(0, math.rad(25), 0) end
    end
end)

-- ESP
RunService.RenderStepped:Connect(function()
    if pvpAtivo.esp then
        for _, v in pairs(Players:GetPlayers()) do
            if v ~= player and v.Character and not v.Character:FindFirstChild("ESP_Box") then
                local box = Instance.new("BoxHandleAdornment")
                box.Name = "ESP_Box"
                box.Size = Vector3.new(4, 5, 4)
                box.Color3 = azul
                box.AlwaysOnTop = true
                box.Adornee = v.Character:FindFirstChild("HumanoidRootPart")
                box.Parent = v.Character
            end
        end
    else
        for _, v in pairs(Players:GetPlayers()) do
            if v.Character then
                local box = v.Character:FindFirstChild("ESP_Box")
                if box then box:Destroy() end
            end
        end
    end
end)

