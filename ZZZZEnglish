local VisualSetters = {}

local function createToggle(text, keybind, enabledKey, callback, order)
    local btn = Instance.new("TextButton")
    btn.Size = UDim2.new(1, -10, 0, 32)
    btn.Text = text .. (keybind ~= "" and " [" .. keybind .. "] " or " ") .. "OFF"
    btn.BackgroundColor3 = Color3.fromRGB(25, 12, 3)
    btn.TextColor3 = Color3.fromRGB(255, 200, 150)
    btn.Font = Enum.Font.GothamBold
    btn.TextSize = 11
    btn.LayoutOrder = order
    btn.Parent = scrollFrame
    Instance.new("UICorner", btn).CornerRadius = UDim.new(0, 6)
    
    local state = Enabled[enabledKey] or false
    if state then
        btn.Text = text .. (keybind ~= "" and " [" .. keybind .. "] " or " ") .. "ON"
        btn.BackgroundColor3 = Color3.fromRGB(80, 50, 20)
        btn.TextColor3 = PINK
    end
    
    local function updateVisual(s)
        state = s
        Enabled[enabledKey] = s
        btn.Text = text .. (keybind ~= "" and " [" .. keybind .. "] " or " ") .. (s and "ON" or "OFF")
        btn.BackgroundColor3 = s and Color3.fromRGB(80, 50, 20) or Color3.fromRGB(25, 12, 3)
        btn.TextColor3 = s and PINK or Color3.fromRGB(255, 200, 150)
        callback(s)
    end
    
    VisualSetters[enabledKey] = updateVisual
    
    btn.MouseButton1Click:Connect(function()
        updateVisual(not state)
    end)
    
    return btn
end

