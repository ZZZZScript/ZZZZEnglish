-- ========== FUNÇÃO CRIAR CARD ==========
local function criarCard(icone, titulo, subtitulo, yPos, corIcone)
    local card = Instance.new("Frame")
    card.Size = UDim2.new(1, 0, 0, 65)
    card.Position = UDim2.new(0, 0, 0, yPos)
    card.BackgroundColor3 = corCard
    card.BackgroundTransparency = 0
    card.Parent = scrollFrame
    Instance.new("UICorner", card).CornerRadius = UDim.new(0, 12)
    Instance.new("UIStroke", card).Color = corBorda
    Instance.new("UIStroke", card).Thickness = 0.5
    Instance.new("UIStroke", card).Transparency = 0.8
    
    -- Efeito hover
    local hoverTween = TweenService:Create(card, TweenInfo.new(0.2), {BackgroundColor3 = Color3.fromRGB(30, 35, 55)})
    local leaveTween = TweenService:Create(card, TweenInfo.new(0.2), {BackgroundColor3 = corCard})
    
    -- Ícone
    local iconLabel = Instance.new("TextLabel")
    iconLabel.Size = UDim2.new(0, 45, 0, 45)
    iconLabel.Position = UDim2.new(0, 12, 0.5, -22.5)
    iconLabel.Text = icone
    iconLabel.Font = Enum.Font.Gotham
    iconLabel.TextSize = 28
    iconLabel.TextColor3 = corIcone or corTextoAzul
    iconLabel.BackgroundTransparency = 1
    iconLabel.Parent = card
    
    -- Título
    local titleCard = Instance.new("TextLabel")
    titleCard.Size = UDim2.new(0, 180, 0, 25)
    titleCard.Position = UDim2.new(0, 65, 0, 12)
    titleCard.Text = titulo
    titleCard.Font = Enum.Font.GothamBold
    titleCard.TextSize = 14
    titleCard.TextColor3 = corTextoBranco
    titleCard.BackgroundTransparency = 1
    titleCard.TextXAlignment = Enum.TextXAlignment.Left
    titleCard.Parent = card
    
    -- Subtítulo
    local subCard = Instance.new("TextLabel")
    subCard.Size = UDim2.new(0, 180, 0, 18)
    subCard.Position = UDim2.new(0, 65, 0, 35)
    subCard.Text = subtitulo
    subCard.Font = Enum.Font.Gotham
    subCard.TextSize = 9
    subCard.TextColor3 = corCinza
    subCard.BackgroundTransparency = 1
    subCard.TextXAlignment = Enum.TextXAlignment.Left
    subCard.Parent = card
    
    -- Botão toggle
    local toggleBtn = Instance.new("TextButton")
    toggleBtn.Size = UDim2.new(0, 55, 0, 30)
    toggleBtn.Position = UDim2.new(1, -70, 0.5, -15)
    toggleBtn.Text = ""
    toggleBtn.BackgroundColor3 = Color3.fromRGB(45, 45, 60)
    toggleBtn.Parent = card
    Instance.new("UICorner", toggleBtn).CornerRadius = UDim.new(1, 0)
    
    -- Círculo do toggle
    local circle = Instance.new("Frame")
    circle.Size = UDim2.new(0, 24, 0, 24)
    circle.Position = UDim2.new(0, 4, 0.5, -12)
    circle.BackgroundColor3 = corTextoBranco
    circle.Parent = toggleBtn
    Instance.new("UICorner", circle).CornerRadius = UDim.new(1, 0)
    
    -- Status
    local statusLabel = Instance.new("TextLabel")
    statusLabel.Size = UDim2.new(0, 40, 0, 20)
    statusLabel.Position = UDim2.new(1, -130, 0.5, -10)
    statusLabel.Text = "OFF"
    statusLabel.Font = Enum.Font.GothamBold
    statusLabel.TextSize = 10
    statusLabel.TextColor3 = Color3.fromRGB(255, 80, 80)
    statusLabel.BackgroundTransparency = 1
    statusLabel.Parent = card
    
    card.MouseEnter:Connect(function() hoverTween:Play() end)
    card.MouseLeave:Connect(function() leaveTween:Play() end)
    
    local ativo = false
    
    local function setAtivo(valor)
        ativo = valor
        if ativo then
            toggleBtn.BackgroundColor3 = corBorda
            circle.Position = UDim2.new(1, -28, 0.5, -12)
            statusLabel.Text = "ON"
            statusLabel.TextColor3 = Color3.fromRGB(80, 255, 80)
        else
            toggleBtn.BackgroundColor3 = Color3.fromRGB(45, 45, 60)
            circle.Position = UDim2.new(0, 4, 0.5, -12)
            statusLabel.Text = "OFF"
            statusLabel.TextColor3 = Color3.fromRGB(255, 80, 80)
        end
    end
    
    toggleBtn.MouseButton1Click:Connect(function()
        setAtivo(not ativo)
        if onToggle then onToggle(ativo) end
    end)
    
    local onToggle = nil
    
    return {
        setAtivo = setAtivo,
        getAtivo = function() return ativo end,
        onToggle = function(callback) onToggle = callback end
    }
end

