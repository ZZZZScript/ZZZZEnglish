-- ========== FUNÇÃO CRIAR CARD ==========
local function criarCard(icone, texto, desc, parent, y)
    local card = Instance.new("Frame")
    card.Size = UDim2.new(1, 0, 0, 65)
    card.Position = UDim2.new(0, 0, 0, y)
    card.BackgroundColor3 = cardBg
    card.Parent = parent
    Instance.new("UICorner", card).CornerRadius = UDim.new(0, 12)
    
    local iconeLab = Instance.new("TextLabel")
    iconeLab.Size = UDim2.new(0, 45, 0, 45)
    iconeLab.Position = UDim2.new(0, 12, 0.5, -22.5)
    iconeLab.Text = icone
    iconeLab.Font = Enum.Font.Gotham
    iconeLab.TextSize = 26
    iconeLab.TextColor3 = azul
    iconeLab.BackgroundTransparency = 1
    iconeLab.Parent = card
    
    local tituloCard = Instance.new("TextLabel")
    tituloCard.Size = UDim2.new(0, 160, 0, 22)
    tituloCard.Position = UDim2.new(0, 65, 0, 10)
    tituloCard.Text = texto
    tituloCard.Font = Enum.Font.GothamBold
    tituloCard.TextSize = 14
    tituloCard.TextColor3 = textoBranco
    tituloCard.BackgroundTransparency = 1
    tituloCard.TextXAlignment = Enum.TextXAlignment.Left
    tituloCard.Parent = card
    
    local descCard = Instance.new("TextLabel")
    descCard.Size = UDim2.new(0, 200, 0, 18)
    descCard.Position = UDim2.new(0, 65, 0, 34)
    descCard.Text = desc
    descCard.Font = Enum.Font.Gotham
    descCard.TextSize = 9
    descCard.TextColor3 = textoClaro
    descCard.BackgroundTransparency = 1
    descCard.TextXAlignment = Enum.TextXAlignment.Left
    descCard.Parent = card
    
    local toggle = Instance.new("TextButton")
    toggle.Size = UDim2.new(0, 52, 0, 28)
    toggle.Position = UDim2.new(1, -62, 0.5, -14)
    toggle.Text = ""
    toggle.BackgroundColor3 = Color3.fromRGB(55, 58, 70)
    toggle.Parent = card
    Instance.new("UICorner", toggle).CornerRadius = UDim.new(1, 0)
    
    local bola = Instance.new("Frame")
    bola.Size = UDim2.new(0, 22, 0, 22)
    bola.Position = UDim2.new(0, 4, 0.5, -11)
    bola.BackgroundColor3 = textoBranco
    bola.Parent = toggle
    Instance.new("UICorner", bola).CornerRadius = UDim.new(1, 0)
    
    local status = Instance.new("TextLabel")
    status.Size = UDim2.new(0, 40, 0, 20)
    status.Position = UDim2.new(1, -118, 0.5, -10)
    status.Text = "OFF"
    status.Font = Enum.Font.GothamBold
    status.TextSize = 9
    status.TextColor3 = Color3.fromRGB(255, 80, 80)
    status.BackgroundTransparency = 1
    status.Parent = card
    
    local ativo = false
    local callback = nil
    
    toggle.MouseButton1Click:Connect(function()
        ativo = not ativo
        if ativo then
            toggle.BackgroundColor3 = azul
            bola.Position = UDim2.new(1, -26, 0.5, -11)
            status.Text = "ON"
            status.TextColor3 = Color3.fromRGB(80, 255, 80)
        else
            toggle.BackgroundColor3 = Color3.fromRGB(55, 58, 70)
            bola.Position = UDim2.new(0, 4, 0.5, -11)
            status.Text = "OFF"
            status.TextColor3 = Color3.fromRGB(255, 80, 80)
        end
        if callback then callback(ativo) end
    end)
    
    return {
        onToggle = function(cb) callback = cb end
    }
end

