-- Simple save function - saves to player
local function saveNow()
    local json = '{"autoAttack":'..tostring(saveData.autoAttack)..
                 ',"esp":'..tostring(saveData.esp)..
                 ',"spin":'..tostring(saveData.spin)..
                 ',"reset":'..tostring(saveData.reset)..
                 ',"jump":'..tostring(saveData.jump)..
                 ',"autoHit":'..tostring(saveData.autoHit)..
                 ',"speed":'..tostring(saveData.speed)..'}'
    
    player:SetAttribute("ZzzSave", json)
    print("💾 SAVED: " .. json)
end

-- Simple load function
local function loadNow()
    local saved = player:GetAttribute("ZzzSave")
    if saved then
        -- Simple parsing without HttpService
        local autoAttack = string.find(saved, '"autoAttack":true') and true or false
        local esp = string.find(saved, '"esp":true') and true or false
        local spin = string.find(saved, '"spin":true') and true or false
        local reset = string.find(saved, '"reset":true') and true or false
        local jump = string.find(saved, '"jump":true') and true or false
        local autoHit = string.find(saved, '"autoHit":true') and true or false
        local speed = string.find(saved, '"speed":true') and true or false
        
        saveData.autoAttack = autoAttack
        saveData.esp = esp
        saveData.spin = spin
        saveData.reset = reset
        saveData.jump = jump
        saveData.autoHit = autoHit
        saveData.speed = speed
        
        print("✅ LOADED: Auto="..tostring(autoAttack).." ESP="..tostring(esp).." Spin="..tostring(spin).." Speed="..tostring(speed))
        
        -- Update UI after loading
        task.wait(0.5)
        for key, ref in pairs(toggleReferences) do
            if ref and ref.toggle and ref.circle then
                local state = saveData[key]
                if state then
                    ref.toggle.BackgroundColor3 = Color3.fromRGB(0,170,0)
                    ref.circle.Position = UDim2.new(1,-20,0.5,-9)
                else
                    ref.toggle.BackgroundColor3 = Color3.fromRGB(80,80,80)
                    ref.circle.Position = UDim2.new(0,2,0.5,-9)
                end
            end
        end
    else
        print("⚠️ No saves found, using defaults")
    end
end

