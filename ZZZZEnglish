RunService.RenderStepped:Connect(function()
    if active.playerESP then
        for _, v in pairs(Players:GetPlayers()) do
            if v ~= player and v.Character and v.Character:FindFirstChild("HumanoidRootPart") then
                if not v.Character:FindFirstChild("ESP_Arrow") then
                    local arrow = Instance.new("BillboardGui")
                    arrow.Name = "ESP_Arrow"
                    arrow.Size = UDim2.new(0, 40, 0, 40)
                    arrow.AlwaysOnTop = true
                    arrow.StudsOffset = Vector3.new(0, 3, 0)
                    
                    local frame = Instance.new("Frame")
                    frame.Size = UDim2.new(1, 0, 1, 0)
                    frame.BackgroundTransparency = 1
                    frame.Parent = arrow
                    
                    local text = Instance.new("TextLabel")
                    text.Size = UDim2.new(1, 0, 1, 0)
                    text.Text = "🔴"
                    text.Font = Enum.Font.Gotham
                    text.TextSize = 32
                    text.TextColor3 = Color3.fromRGB(255, 0, 0)
                    text.BackgroundTransparency = 1
                    text.Parent = frame
                    
                    arrow.Parent = v.Character:FindFirstChild("HumanoidRootPart")
                end
            end
        end
    else
        for _, v in pairs(Players:GetPlayers()) do
            if v.Character then
                local arrow = v.Character:FindFirstChild("ESP_Arrow")
                if arrow then arrow:Destroy() end
            end
        end
    end
end)

