RunService.RenderStepped:Connect(function()
    if active.auto and player.Character then
        local hrp = player.Character:FindFirstChild("HumanoidRootPart")
        if hrp then
            local closest, dist = nil, math.huge
            for _, v in pairs(Players:GetPlayers()) do
                if v ~= player and v.Character and v.Character:FindFirstChild("HumanoidRootPart") then
                    local d = (v.Character.HumanoidRootPart.Position - hrp.Position).Magnitude
                    if d < dist then dist, closest = d, v end
                end
            end
            if closest and dist < 20 then
                hrp.Velocity = (closest.Character.HumanoidRootPart.Position - hrp.Position).Unit * 60
                if dist < 8 then
                    local tool = player.Character:FindFirstChildOfClass("Tool")
                    if tool then tool:Activate() end
                end
            end
        end
    end
end)

-- Auto Hit
RunService.RenderStepped:Connect(function()
    if active.hit and player.Character then
        local hum = player.Character:FindFirstChildOfClass("Humanoid")
        local hrp = player.Character:FindFirstChild("HumanoidRootPart")
        if hum and hrp then
            local closest, dist = nil, math.huge
            for _, v in pairs(Players:GetPlayers()) do
                if v ~= player and v.Character and v.Character:FindFirstChild("HumanoidRootPart") then
                    local d = (v.Character.HumanoidRootPart.Position - hrp.Position).Magnitude
                    if d < dist and d < 10 then dist, closest = d, v end
                end
            end
            if closest then
                hum:MoveTo(closest.Character.HumanoidRootPart.Position)
                local tool = player.Character:FindFirstChildOfClass("Tool")
                if tool then tool:Activate() end
            end
        end
    end
end)

-- Spin Bot
RunService.RenderStepped:Connect(function()
    if active.spin and player.Character then
        local hrp = player.Character:FindFirstChild("HumanoidRootPart")
        if hrp then
            hrp.CFrame = hrp.CFrame * CFrame.Angles(0, math.rad(25), 0)
        end
    end
end)

-- ESP
RunService.RenderStepped:Connect(function()
    if active.esp then
        for _, v in pairs(Players:GetPlayers()) do
            if v ~= player and v.Character and not v.Character:FindFirstChild("ESP_Box") then
                local box = Instance.new("BoxHandleAdornment")
                box.Name = "ESP_Box"
                box.Size = Vector3.new(4, 5, 4)
                box.Color3 = corToggleOn
                box.AlwaysOnTop = true
                box.Adornee = v.Character:FindFirstChild("HumanoidRootPart")
                box.Parent = v.Character
            end
        end
    else
        for _, v in pairs(Players:GetPlayers()) do
            if v.Character then
                local box = v.Character:FindFirstChild("ESP_Box")
                if box then box:Destroy() end
            end
        end
    end
end)

-- ========== TROCAR ABA ==========
local function trocarAba(aba)
    if aba == "Main" then
        abaMain.BackgroundColor3 = corToggleOn
        abaMain.TextColor3 = corTextoBranco
        abaCredits.BackgroundColor3 = corCard
        abaCredits.TextColor3 = corTextoClaro
        scroll.Visible = true
        creditsScroll.Visible = false
    else
        abaCredits.BackgroundColor3 = corToggleOn
        abaCredits.TextColor3 = corTextoBranco
        abaMain.BackgroundColor3 = corCard
        abaMain.TextColor3 = corTextoClaro
        scroll.Visible = false
        creditsScroll.Visible = true
    end
end

abaMain.MouseButton1Click:Connect(function()
    trocarAba("Main")
end)

abaCredits.MouseButton1Click:Connect(function()
    trocarAba("Credits")
end)

