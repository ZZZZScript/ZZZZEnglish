-- Float
local floatConn = nil
local floatDescending = false
local floatStartTime = 0

local function startFloat()
    if floatConn then return end
    floatDescending = false
    floatStartTime = tick()
    
    floatConn = RunService.Heartbeat:Connect(function()
        if not Enabled.Float then return end
        local c = Player.Character
        if not c then return end
        local h = c:FindFirstChild("HumanoidRootPart")
        if not h then return end
        local hum = c:FindFirstChildOfClass("Humanoid")
        local moveDir = hum and hum.MoveDirection or Vector3.zero
        
        if tick() - floatStartTime >= 4 then 
            floatDescending = true 
        end
        
        local currentY = h.Position.Y
        local vertVel = 0
        
        if not floatDescending then
            local targetY = h.Position.Y + 2
            vertVel = math.clamp((targetY - currentY) * 5, -15, 15)
        else
            vertVel = -15
            if currentY <= 2 then
                h.AssemblyLinearVelocity = Vector3.zero
                Enabled.Float = false
                if floatConn then 
                    floatConn:Disconnect() 
                    floatConn = nil 
                end
                return
            end
        end
        
        local horizX = moveDir.Magnitude > 0.1 and moveDir.X * Values.BoostSpeed or 0
        local horizZ = moveDir.Magnitude > 0.1 and moveDir.Z * Values.BoostSpeed or 0
        h.AssemblyLinearVelocity = Vector3.new(horizX, vertVel, horizZ)
    end)
end

local function stopFloat()
    if floatConn then 
        floatConn:Disconnect() 
        floatConn = nil 
    end
end

-- Unwalk
local savedAnimations = {}

local function startUnwalk()
    local c = Player.Character
    if not c then return end
    local hum = c:FindFirstChildOfClass("Humanoid")
    if hum then 
        for _, t in ipairs(hum:GetPlayingAnimationTracks()) do 
            t:Stop() 
        end
    end
    local anim = c:FindFirstChild("Animate")
    if anim then 
        savedAnimations.Animate = anim:Clone() 
        anim:Destroy() 
    end
end

local function stopUnwalk()
    local c = Player.Character
    if c and savedAnimations.Animate and not c:FindFirstChild("Animate") then
        savedAnimations.Animate:Clone().Parent = c
        savedAnimations.Animate = nil
    end
end

-- Hit Circle
