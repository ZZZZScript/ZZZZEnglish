-- AUTO SELL FUNCTION (only sells selected items)
local function autoSell()
    if not settings.autoSell then return end
    
    -- Check workspace
    for _, item in pairs(workspace:GetDescendants()) do
        if item:IsA("Model") or item:IsA("Part") or item:IsA("Tool") then
            local itemName = item.Name
            for sellName, selected in pairs(selectedItems) do
                if selected and (string.find(itemName, sellName) or string.find(sellName, itemName)) then
                    pcall(function()
                        if item:IsA("Tool") then
                            item:Destroy()
                        elseif item.Parent then
                            item:Destroy()
                        end
                        print("💰 Auto Sold: " .. itemName)
                    end)
                    break
                end
            end
        end
    end
    
    -- Check Backpack
    if player.Backpack then
        for _, tool in pairs(player.Backpack:GetChildren()) do
            for sellName, selected in pairs(selectedItems) do
                if selected and (string.find(tool.Name, sellName) or string.find(sellName, tool.Name)) then
                    pcall(function()
                        tool:Destroy()
                        print("💰 Auto Sold from Backpack: " .. tool.Name)
                    end)
                    break
                end
            end
        end
    end
    
    -- Check Character
    if player.Character then
        for _, tool in pairs(player.Character:GetChildren()) do
            if tool:IsA("Tool") then
                for sellName, selected in pairs(selectedItems) do
                    if selected and (string.find(tool.Name, sellName) or string.find(sellName, tool.Name)) then
                        pcall(function()
                            tool:Destroy()
                            print("💰 Auto Sold from Character: " .. tool.Name)
                        end)
                        break
                    end
                end
            end
        end
    end
end

-- Run Auto Sell every second
spawn(function()
    while true do
        task.wait(1)
        autoSell()
    end
end)

