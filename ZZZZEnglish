-- Anchor (Anti-Knockback)
local anchorAtivo = false
local posAncora = nil
local conexaoAnchor = nil

anchorBtn.MouseButton1Click:Connect(function()
    anchorAtivo = not anchorAtivo
    print("Anchor: " .. (anchorAtivo and "ON" or "OFF"))
    
    if anchorAtivo then
        if player.Character and player.Character:FindFirstChild("HumanoidRootPart") then
            posAncora = player.Character.HumanoidRootPart.Position
        end
        
        if conexaoAnchor then conexaoAnchor:Disconnect() end
        
        conexaoAnchor = RunService.Heartbeat:Connect(function()
            if anchorAtivo and player.Character then
                local hrp = player.Character:FindFirstChild("HumanoidRootPart")
                if hrp then
                    if not posAncora then
                        posAncora = hrp.Position
                    end
                    
                    local distancia = (hrp.Position - posAncora).Magnitude
                    if distancia > 3 then
                        hrp.CFrame = CFrame.new(posAncora)
                        local hum = player.Character:FindFirstChildOfClass("Humanoid")
                        if hum then
                            hum:ChangeState(Enum.HumanoidStateType.GettingUp)
                        end
                    end
                    
                    posAncora = posAncora:Lerp(hrp.Position, 0.1)
                end
            end
        end)
    else
        if conexaoAnchor then
            conexaoAnchor:Disconnect()
            conexaoAnchor = nil
        end
        posAncora = nil
    end
end)

