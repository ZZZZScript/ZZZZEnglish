-- Function to create selectable item row
local function createItemRow(panel, itemName, yPos)
    local row = Instance.new("Frame", panel)
    row.Size = UDim2.new(0.96,0,0,28)
    row.Position = UDim2.new(0.02,0,0,yPos)
    row.BackgroundColor3 = Color3.fromRGB(30,30,30)
    Instance.new("UICorner", row).CornerRadius = UDim.new(0,4)
    
    local label = Instance.new("TextLabel", row)
    label.Size = UDim2.new(0.75,0,1,0)
    label.Position = UDim2.new(0,8,0,0)
    label.Text = itemName
    label.Font = Enum.Font.Gotham
    label.TextSize = 9
    label.TextColor3 = Color3.new(1,1,1)
    label.BackgroundTransparency = 1
    label.TextXAlignment = Enum.TextXAlignment.Left
    
    local checkBox = Instance.new("TextButton", row)
    checkBox.Size = UDim2.new(0,20,0,20)
    checkBox.Position = UDim2.new(1,-28,0.5,-10)
    checkBox.Text = selectedItems[itemName] and "✓" or ""
    checkBox.Font = Enum.Font.GothamBold
    checkBox.TextSize = 12
    checkBox.TextColor3 = Color3.new(1,1,1)
    checkBox.BackgroundColor3 = selectedItems[itemName] and Color3.fromRGB(0,170,0) or Color3.fromRGB(80,80,80)
    Instance.new("UICorner", checkBox).CornerRadius = UDim.new(0,4)
    
    checkBox.MouseButton1Click:Connect(function()
        selectedItems[itemName] = not selectedItems[itemName]
        if selectedItems[itemName] then
            checkBox.Text = "✓"
            checkBox.BackgroundColor3 = Color3.fromRGB(0,170,0)
        else
            checkBox.Text = ""
            checkBox.BackgroundColor3 = Color3.fromRGB(80,80,80)
        end
        saveSettings()
    end)
    
    itemButtons[itemName] = checkBox
    return row
end

