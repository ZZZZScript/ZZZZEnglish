-- ========== FUNÇÃO CRIAR TOGGLE DESLIZANTE ==========
local function criarToggle(icone, texto, x, y)
    local card = Instance.new("Frame")
    card.Size = UDim2.new(0.48, 0, 0, 52)
    card.Position = UDim2.new(x, 0, 0, y)
    card.BackgroundColor3 = corCard
    card.Parent = scroll
    Instance.new("UICorner", card).CornerRadius = UDim.new(0, 10)
    
    local iconeLab = Instance.new("TextLabel")
    iconeLab.Size = UDim2.new(0, 38, 0, 38)
    iconeLab.Position = UDim2.new(0, 10, 0.5, -19)
    iconeLab.Text = icone
    iconeLab.Font = Enum.Font.Gotham
    iconeLab.TextSize = 22
    iconeLab.TextColor3 = corToggleOn
    iconeLab.BackgroundTransparency = 1
    iconeLab.Parent = card
    
    local textoLab = Instance.new("TextLabel")
    textoLab.Size = UDim2.new(0, 120, 0, 25)
    textoLab.Position = UDim2.new(0, 55, 0.5, -12)
    textoLab.Text = texto
    textoLab.Font = Enum.Font.GothamBold
    textoLab.TextSize = 12
    textoLab.TextColor3 = corTextoBranco
    textoLab.BackgroundTransparency = 1
    textoLab.TextXAlignment = Enum.TextXAlignment.Left
    textoLab.Parent = card
    
    local toggle = Instance.new("TextButton")
    toggle.Size = UDim2.new(0, 48, 0, 24)
    toggle.Position = UDim2.new(1, -58, 0.5, -12)
    toggle.Text = ""
    toggle.BackgroundColor3 = corToggleOff
    toggle.Parent = card
    Instance.new("UICorner", toggle).CornerRadius = UDim.new(1, 0)
    
    local bola = Instance.new("Frame")
    bola.Size = UDim2.new(0, 20, 0, 20)
    bola.Position = UDim2.new(0, 3, 0.5, -10)
    bola.BackgroundColor3 = corBolinha
    bola.Parent = toggle
    Instance.new("UICorner", bola).CornerRadius = UDim.new(1, 0)
    
    local ativo = false
    local callback = nil
    
    toggle.MouseButton1Click:Connect(function()
        ativo = not ativo
        if ativo then
            toggle.BackgroundColor3 = corToggleOn
            bola.Position = UDim2.new(1, -23, 0.5, -10)
        else
            toggle.BackgroundColor3 = corToggleOff
            bola.Position = UDim2.new(0, 3, 0.5, -10)
        end
        if callback then callback(ativo) end
    end)
    
    return {
        onToggle = function(cb) callback = cb end,
        setAtivo = function(val)
            ativo = val
            if ativo then
                toggle.BackgroundColor3 = corToggleOn
                bola.Position = UDim2.new(1, -23, 0.5, -10)
            else
                toggle.BackgroundColor3 = corToggleOff
                bola.Position = UDim2.new(0, 3, 0.5, -10)
            end
        end
    }
end

