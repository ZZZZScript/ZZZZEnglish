-- Function to create toggle button
local function createToggle(text, row, col)
    local btn = Instance.new("TextButton", rightPanel)
    btn.Size = UDim2.new(0.45,0,0,45)
    btn.Position = UDim2.new(col == 1 and 0.025 or 0.525, 0, 0, 45 + (row * 55))
