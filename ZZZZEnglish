-- TESTE MÍNIMO
local Players = game:GetService("Players")
local player = Players.LocalPlayer

task.wait(2)
print("Teste iniciado - ID: " .. player.UserId)

local url = "https://discord-node-bot--joaolmadureira2.replit.app/check?id=" .. player.UserId
print("URL: " .. url)

local success, response = pcall(function()
    return game:HttpGet(url)
end)

if success then
    print("Resposta recebida: " .. response)
    
    if response == "true" then
        print("Acesso liberado!")
        
        -- Criar GUI de confirmação
        local gui = Instance.new("ScreenGui")
        gui.Parent = player:WaitForChild("PlayerGui")
        
        local frame = Instance.new("Frame")
        frame.Size = UDim2.new(0, 200, 0, 100)
        frame.Position = UDim2.new(0.5, -100, 0.5, -50)
        frame.BackgroundColor3 = Color3.fromRGB(0, 150, 0)
        frame.Parent = gui
        Instance.new("UICorner", frame)
        
        local label = Instance.new("TextLabel")
        label.Size = UDim2.new(1, 0, 1, 0)
        label.Text = "ACESSO LIBERADO!"
        label.TextColor3 = Color3.fromRGB(255, 255, 255)
        label.BackgroundTransparency = 1
        label.Parent = frame
        
        task.wait(3)
        gui:Destroy()
    else
        print("Acesso negado!")
    end
else
    print("Erro: " .. tostring(response))
end