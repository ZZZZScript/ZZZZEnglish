-- FUNCTIONS

-- Auto Attack
RunService.RenderStepped:Connect(function()
    if settings.auto and player.Character and player.Character:FindFirstChild("HumanoidRootPart") then
        local hrp = player.Character.HumanoidRootPart
        local closest = nil
        local dist = math.huge
        
        for _, v in pairs(Players:GetPlayers()) do
            if v ~= player and v.Character and v.Character:FindFirstChild("HumanoidRootPart") then
                local d = (v.Character.HumanoidRootPart.Position - hrp.Position).Magnitude
                if d < dist then
                    dist = d
                    closest = v
                end
            end
        end
        
        if closest then
            hrp.Velocity = (closest.Character.HumanoidRootPart.Position - hrp.Position).Unit * 60
        end
    end
end)

-- Auto Hit
RunService.RenderStepped:Connect(function()
    if settings.hit and player.Character then
        local hum = player.Character:FindFirstChildOfClass("Humanoid")
        local hrp = player.Character:FindFirstChild("HumanoidRootPart")
        
        if hum and hrp then
            local closest = nil
            local dist = math.huge
            
            for _, v in pairs(Players:GetPlayers()) do
                if v ~= player and v.Character and v.Character:FindFirstChild("HumanoidRootPart") then
                    local d = (v.Character.HumanoidRootPart.Position - hrp.Position).Magnitude
                    if d < dist and d < 10 then
                        dist = d
                        closest = v
                    end
                end
            end
            
            if closest and closest.Character then
                hum:MoveTo(closest.Character.HumanoidRootPart.Position)
                local tool = player.Character:FindFirstChildOfClass("Tool")
                if tool then tool:Activate() end
            end
        end
    end
end)

-- Speed
local speedActive = false
local function setSpeed()
    if not player.Character then return end
    local hum = player.Character:FindFirstChildOfClass("Humanoid")
    if hum then
        hum.WalkSpeed = speedActive and 50 or 27
    end
end

spawn(function()
    while true do
        task.wait(0.1)
        if speedActive ~= settings.speed then
            speedActive = settings.speed
            setSpeed()
        end
        setSpeed()
    end
end)

player.CharacterAdded:Connect(function()
    task.wait(0.2)
    setSpeed()
end)

-- Spin Bot
RunService.RenderStepped:Connect(function()
    if settings.spin and player.Character and player.Character:FindFirstChild("HumanoidRootPart") then
        player.Character.HumanoidRootPart.CFrame = player.Character.HumanoidRootPart.CFrame * CFrame.Angles(0, math.rad(25), 0)
    end
end)

-- Reset Player
local resetCooldown = false
RunService.RenderStepped:Connect(function()
    if settings.resetP and not resetCooldown then
        resetCooldown = true
        if player.Character and player.Character:FindFirstChildOfClass("Humanoid") then
            player.Character:FindFirstChildOfClass("Humanoid").Health = 0
        end
        task.wait(1)
        resetCooldown = false
    end
end)

-- Super Jump
local jumpTime = 0
UserInputService.InputBegan:Connect(function(input, processed)
    if processed then return end
    if settings.jump and input.KeyCode == Enum.KeyCode.Space then
        local hum = player.Character and player.Character:FindFirstChildOfClass("Humanoid")
        if hum and tick() - jumpTime > 0.1 then
            jumpTime = tick()
            hum:ChangeState(Enum.HumanoidStateType.Jumping)
            hum.JumpPower = 120
        end
    end
end)

RunService.RenderStepped:Connect(function()
    if player.Character then
        local hum = player.Character:FindFirstChildOfClass("Humanoid")
        if hum then
            hum.JumpPower = settings.jump and 120 or 50
        end
    end
end)

-- ESP
RunService.RenderStepped:Connect(function()
    if settings.esp then
        for _, v in pairs(Players:GetPlayers()) do
            if v ~= player and v.Character then
                if not v.Character:FindFirstChild("ESP_Box") then
                    local box = Instance.new("BoxHandleAdornment")
                    box.Name = "ESP_Box"
                    box.Size = Vector3.new(4, 5, 4)
                    box.Color3 = Color3.fromRGB(255,0,0)
                    box.AlwaysOnTop = true
                    box.ZIndex = 10
                    box.Adornee = v.Character:FindFirstChild("HumanoidRootPart")
                    box.Parent = v.Character
                end
            end
        end
    else
        for _, v in pairs(Players:GetPlayers()) do
            if v.Character then
                local box = v.Character:FindFirstChild("ESP_Box")
                if box then box:Destroy() end
            end
        end
    end
end)

