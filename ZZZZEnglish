    bola.Position = UDim2.new(0, 2, 0.5, -8)
    bola.BackgroundColor3 = Color3.fromRGB(220, 220, 230)
    bola.Parent = toggle
    Instance.new("UICorner", bola).CornerRadius = UDim.new(1, 0)
    
    local ativo = false
    local callback = nil
    
    toggle.MouseButton1Click:Connect(function()
        ativo = not ativo
