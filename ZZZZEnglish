local function createCard(nome, icone, yPos, callback)
    local card = Instance.new("Frame")
    card.Size = UDim2.new(1, 0, 0, 55)
    card.Position = UDim2.new(0, 0, 0, yPos)
    card.BackgroundColor3 = corCard
    card.BackgroundTransparency = 0.2
    card.Parent = scrollFrame
    Instance.new("UICorner", card).CornerRadius = UDim.new(0, 12)
    
    -- Efeito hover
    local hoverTween = TweenService:Create(card, TweenInfo.new(0.2), {BackgroundTransparency = 0})
    
    -- Ícone
    local icon = Instance.new("TextLabel")
    icon.Size = UDim2.new(0, 40, 0, 40)
    icon.Position = UDim2.new(0, 12, 0.5, -20)
    icon.Text = icone
    icon.Font = Enum.Font.Gotham
    icon.TextSize = 24
    icon.TextColor3 = corPrincipal
    icon.BackgroundTransparency = 1
    icon.Parent = card
    
    -- Nome
    local label = Instance.new("TextLabel")
    label.Size = UDim2.new(0, 150, 0, 25)
    label.Position = UDim2.new(0, 60, 0, 15)
    label.Text = nome
    label.Font = Enum.Font.GothamBold
    label.TextSize = 13
    label.TextColor3 = corTexto
    label.BackgroundTransparency = 1
    label.TextXAlignment = Enum.TextXAlignment.Left
    label.Parent = card
    
    -- Status (ON/OFF)
    local status = Instance.new("TextLabel")
    status.Size = UDim2.new(0, 45, 0, 20)
    status.Position = UDim2.new(0, 60, 0, 38)
    status.Text = "OFF"
    status.Font = Enum.Font.Gotham
    status.TextSize = 9
    status.TextColor3 = Color3.fromRGB(255, 100, 100)
    status.BackgroundTransparency = 1
    status.TextXAlignment = Enum.TextXAlignment.Left
    status.Parent = card
    
    -- Botão toggle
    local toggle = Instance.new("TextButton")
    toggle.Size = UDim2.new(0, 50, 0, 28)
    toggle.Position = UDim2.new(1, -62, 0.5, -14)
    toggle.Text = ""
    toggle.BackgroundColor3 = Color3.fromRGB(50, 50, 60)
    toggle.Parent = card
    Instance.new("UICorner", toggle).CornerRadius = UDim.new(1, 0)
    
    -- Círculo do toggle
    local circle = Instance.new("Frame")
    circle.Size = UDim2.new(0, 22, 0, 22)
    circle.Position = UDim2.new(0, 3, 0.5, -11)
    circle.BackgroundColor3 = corTexto
    circle.Parent = toggle
    Instance.new("UICorner", circle).CornerRadius = UDim.new(1, 0)
    
    local active = false
    
    toggle.MouseButton1Click:Connect(function()
        active = not active
        if active then
            toggle.BackgroundColor3 = corPrincipal
            circle.Position = UDim2.new(1, -25, 0.5, -11)
            status.Text = "ON"
            status.TextColor3 = Color3.fromRGB(100, 255, 100)
        else
            toggle.BackgroundColor3 = Color3.fromRGB(50, 50, 60)
            circle.Position = UDim2.new(0, 3, 0.5, -11)
            status.Text = "OFF"
            status.TextColor3 = Color3.fromRGB(255, 100, 100)
        end
        callback(active)
    end)
    
    card.MouseEnter:Connect(function()
        hoverTween:Play()
    end)
    
    card.MouseLeave:Connect(function()
        hoverTween:Reverse()
    end)
    
    return {card = card, active = active, setActive = function(val)
        active = val
        if active then
            toggle.BackgroundColor3 = corPrincipal
            circle.Position = UDim2.new(1, -25, 0.5, -11)
            status.Text = "ON"
            status.TextColor3 = Color3.fromRGB(100, 255, 100)
        else
            toggle.BackgroundColor3 = Color3.fromRGB(50, 50, 60)
            circle.Position = UDim2.new(0, 3, 0.5, -11)
            status.Text = "OFF"
            status.TextColor3 = Color3.fromRGB(255, 100, 100)
        end
        callback(active)
    end}
end

