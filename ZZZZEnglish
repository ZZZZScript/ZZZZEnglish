-- Super Jump
local jumpTime = 0
UserInputService.InputBegan:Connect(function(input)
    if activeFunctions.jump and input.KeyCode == Enum.KeyCode.Space and not flyingActive then
        local hum = player.Character and player.Character:FindFirstChildOfClass("Humanoid")
        if hum and tick() - jumpTime > 0.1 then
            jumpTime = tick()
            hum:ChangeState(Enum.HumanoidStateType.Jumping)
            hum.JumpPower = 120
        end
    end
end)

RunService.RenderStepped:Connect(function()
    if player.Character and not flyingActive then
        local hum = player.Character:FindFirstChildOfClass("Humanoid")
        if hum then hum.JumpPower = activeFunctions.jump and 120 or 50 end
