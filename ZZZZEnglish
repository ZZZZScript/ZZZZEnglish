            valorLabel.Size = UDim2.new(0, 50, 0, 20)
            valorLabel.Position = UDim2.new(1, -58, 0.15, 0)
            valorLabel.Text = tostring(valorInicial)
            valorLabel.Font = Enum.Font.GothamBold
            valorLabel.TextSize = 10
            valorLabel.TextColor3 = Color3.fromRGB(100, 200, 255)
            valorLabel.BackgroundTransparency = 1
            valorLabel.Parent = card
            
            local slider = Instance.new("Frame")
            slider.Size = UDim2.new(0.7, 0, 0, 4)
            slider.Position = UDim2.new(0, 42, 0.6, 0)
            slider.BackgroundColor3 = Color3.fromRGB(55, 55, 65)
            slider.Parent = card
            Instance.new("UICorner", slider).CornerRadius = UDim.new(1, 0)
            
            local fill = Instance.new("Frame")
            fill.Size = UDim2.new((valorInicial - minVal) / (maxVal - minVal), 0, 1, 0)
            fill.BackgroundColor3 = Color3.fromRGB(100, 100, 200)
            fill.Parent = slider
            Instance.new("UICorner", fill).CornerRadius = UDim.new(1, 0)
            
            local knob = Instance.new("TextButton")
            knob.Size = UDim2.new(0, 12, 0, 12)
            knob.Position = UDim2.new((valorInicial - minVal) / (maxVal - minVal), -6, 0.5, -6)
            knob.BackgroundColor3 = Color3.fromRGB(200, 200, 255)
            knob.Text = ""
            knob.Parent = slider
            Instance.new("UICorner", knob).CornerRadius = UDim.new(1, 0)
            
            local dragging = false
            
            local function updateValue(inputPos)
                local sliderPos = slider.AbsolutePosition.X
                local sliderWidth = slider.AbsoluteSize.X
                local percent = math.clamp((inputPos - sliderPos) / sliderWidth, 0, 1)
                local newValue = math.floor(minVal + (maxVal - minVal) * percent + 0.5)
                newValue = math.clamp(newValue, minVal, maxVal)
                
                fill.Size = UDim2.new(percent, 0, 1, 0)
                knob.Position = UDim2.new(percent, -6, 0.5, -6)
                valorLabel.Text = tostring(newValue)
                
                if texto == "Speed" then
                    velocidadeAtual = newValue
                    if speedAtivo then
                        local character = player.Character
                        if character then
                            local hum = character:FindFirstChildOfClass("Humanoid")
                            if hum then hum.WalkSpeed = velocidadeAtual end
                        end
                    end
                end
            end
            
            knob.MouseButton1Down:Connect(function()
                dragging = true
                local connection
                connection = UserInputService.InputChanged:Connect(function(input)
                    if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
                        updateValue(input.Position.X)
                    end
                end)
                UserInputService.InputEnded:Connect(function(input)
                    if input.UserInputType == Enum.UserInputType.MouseButton1 then
                        dragging = false
                        connection:Disconnect()
                    end
                end)
            end)
            
            return knob, valorLabel
        end

