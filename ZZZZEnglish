-- ========== AUTO COLLECT MONEY (CORRIGIDO) ==========
local collectActive = false

-- Função para coletar dinheiro remotamente
local function autoCollectMoneyFunction()
    if not collectActive then return end
    
    -- Tentar encontrar e coletar dinheiro
    local function tryCollect(obj)
        pcall(function()
            -- Tentar destruir o objeto
            if obj and obj.Parent then
                obj:Destroy()
                return true
            end
            return false
        end)
    end
    
    -- Procurar em todo workspace
    for _, obj in pairs(workspace:GetDescendants()) do
        local nome = (obj.Name or ""):lower()
        
        -- Lista de nomes de itens de dinheiro/brainrot
        local moneyNames = {
            "coin", "money", "cash", "drop", "brainrot", "brain", "rot",
            "noobini", "lirili", "fluri", "cacto", "pipi", "tric", "burbaloni",
            "boneca", "trippi", "svinina", "bambini", "avocadini", "bandito", "tatatata",
            "gangster", "tung", "cappuccino", "orangutini", "talpa", "espresso",
            "brr", "rhino", "strawberelli", "bananito", "balerina", "glorbo",
            "blueberrinni", "chimpanzini", "bombardiro", "elefanto", "bombombini", "pandaccini",
            "gorillo", "frigo", "girafa", "ganganzelli", "tigroligre", "matteo",
            "vacca", "esok", "tralaledon", "tralalero", "chicleteira", "tortugini",
            "quesadilla", "caramelini", "penguino", "cupcake", "cookie", "capitano",
            "elefanto geladerino", "meowl", "smurf", "capitão clash", "strawberry elephant"
        }
        
        local isMoney = false
        for _, moneyName in pairs(moneyNames) do
            if string.find(nome, moneyName) then
                isMoney = true
                break
            end
        end
        
        -- Verificar se é um item de brainrot pelo nome
        if isMoney then
            if obj:IsA("BasePart") or obj:IsA("Model") or obj:IsA("Tool") then
                tryCollect(obj)
            end
        end
        
        -- Verificar se tem um valor de cash/money
        if obj:IsA("NumberValue") and (nome:find("cash") or nome:find("money") or nome:find("value")) then
            tryCollect(obj)
        end
        
        -- Verificar se é um ClickDetector (coletável)
        if obj:IsA("ClickDetector") then
            local parent = obj.Parent
            if parent then
                tryCollect(parent)
            end
            tryCollect(obj)
        end
    end
    
    -- Procurar no inventário do jogador
    if player.Backpack then
        for _, item in pairs(player.Backpack:GetChildren()) do
            local nomeItem = (item.Name or ""):lower()
            for _, moneyName in pairs(moneyNames) do
                if string.find(nomeItem, moneyName) then
                    pcall(function() item:Destroy() end)
                    break
                end
            end
        end
    end
    
    -- Procurar no personagem
    if player.Character then
        for _, item in pairs(player.Character:GetChildren()) do
            if item:IsA("Tool") then
                local nomeItem = (item.Name or ""):lower()
                for _, moneyName in pairs(moneyNames) do
                    if string.find(nomeItem, moneyName) then
                        pcall(function() item:Destroy() end)
                        break
                    end
                end
            end
        end
    end
end

