-- Função melhorada para coletar dinheiro
local function collectMoney()
    if not coletando then return end
    
    local char = player.Character
    if not char then return end
    
    local root = char:FindFirstChild("HumanoidRootPart")
    if not root then return end
    
    local collected = false
    
    -- Procurar por objetos de dinheiro
    for _, obj in pairs(workspace:GetDescendants()) do
        if obj and obj.Parent then
            local objName = obj.Name:lower()
            local isMoneyObject = false
            
            -- Verificar se é um objeto de dinheiro
            if obj:IsA("BasePart") then
                if objName:find("coin") or objName:find("money") or objName:find("cash") or 
                   objName:find("diamond") or objName:find("crystal") or objName:find("gem") then
                    isMoneyObject = true
                end
            elseif obj:IsA("Model") then
                if objName:find("coin") or objName:find("money") or objName:find("cash") or 
                   objName:find("diamond") or objName:find("crystal") or objName:find("gem") or
                   obj:FindFirstChild("TouchInterest") then
                    isMoneyObject = true
                end
            end
            
            if isMoneyObject then
                pcall(function()
                    -- Tentar teleportar o objeto para o jogador
                    if obj:IsA("BasePart") then
                        local success, errorMsg = pcall(function()
                            obj.CFrame = root.CFrame
                        end)
                        
                        if success then
                            collected = true
                            task.wait(0.05)
                            obj:Destroy()
                        end
                    elseif obj:IsA("Model") then
                        -- Para modelos, mover todos os BaseParts
                        local parts = {}
                        for _, part in pairs(obj:GetDescendants()) do
                            if part:IsA("BasePart") then
                                table.insert(parts, part)
                            end
                        end
                        
                        for _, part in pairs(parts) do
                            pcall(function()
                                part.CFrame = root.CFrame
                            end)
                        end
                        
                        collected = true
                        task.wait(0.05)
                        obj:Destroy()
                    end
                end)
            end
        end
    end
    
    return collected
end

-- Loop de coleta otimizado
spawn(function()
    while true do
        if coletando then
            collectMoney()
        end
        task.wait(0.1)
    end
end)

-- Detectar novos objetos que aparecem
local function onDescendantAdded(descendant)
    if not coletando then return end
    
    task.wait(0.1)
    local objName = descendant.Name:lower()
    local isMoneyObject = false
    
    if descendant:IsA("BasePart") then
        if objName:find("coin") or objName:find("money") or objName:find("cash") or 
           objName:find("diamond") or objName:find("crystal") or objName:find("gem") then
            isMoneyObject = true
        end
    elseif descendant:IsA("Model") then
        if objName:find("coin") or objName:find("money") or objName:find("cash") or 
           objName:find("diamond") or objName:find("crystal") or objName:find("gem") then
            isMoneyObject = true
        end
    end
    
    if isMoneyObject and descendant.Parent then
        local char = player.Character
        if char and char:FindFirstChild("HumanoidRootPart") then
            pcall(function()
                task.wait(0.05)
                if descendant:IsA("BasePart") then
                    descendant.CFrame = char.HumanoidRootPart.CFrame
                    descendant:Destroy()
                elseif descendant:IsA("Model") then
                    descendant:Destroy()
                end
            end)
        end
    end
end

workspace.DescendantAdded:Connect(onDescendantAdded)

