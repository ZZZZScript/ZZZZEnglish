local function createToggle(text, keybind, order)
    local btn = Instance.new("TextButton")
    btn.Size = UDim2.new(1, -10, 0, 32)
    btn.Text = text .. " [" .. keybind .. "] OFF"
    btn.BackgroundColor3 = Color3.fromRGB(25, 12, 3)
    btn.TextColor3 = Color3.fromRGB(255, 200, 150)
    btn.Font = Enum.Font.GothamBold
    btn.TextSize = 11
    btn.LayoutOrder = order
    btn.Parent = scrollFrame
    Instance.new("UICorner", btn).CornerRadius = UDim.new(0, 6)
    
    local state = false
    
    btn.MouseButton1Click:Connect(function()
        state = not state
        btn.Text = text .. " [" .. keybind .. "] " .. (state and "ON" or "OFF")
        btn.BackgroundColor3 = state and Color3.fromRGB(80, 50, 20) or Color3.fromRGB(25, 12, 3)
        btn.TextColor3 = state and PINK or Color3.fromRGB(255, 200, 150)
        
        -- Simulação das funções (você pode adicionar as funções reais aqui)
        if text == "Speed Boost" then
            if state then
                -- ativar speed
            else
                -- desativar speed
            end
        end
    end)
    
    return btn
end

