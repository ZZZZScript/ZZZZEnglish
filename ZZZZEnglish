-- ========== ANCHOR ==========
local anchorAtivo = false
local anchorPosition = nil
local anchorConnection = nil

anchor.onToggle(function(v)
    anchorAtivo = v
    print("Anchor: " .. (v and "ON" or "OFF"))
    
    if anchorAtivo then
        if player.Character and player.Character:FindFirstChild("HumanoidRootPart") then
            anchorPosition = player.Character.HumanoidRootPart.Position
        end
        
        if anchorConnection then anchorConnection:Disconnect() end
        
        anchorConnection = RunService.Heartbeat:Connect(function()
            if anchorAtivo and player.Character then
                local hrp = player.Character:FindFirstChild("HumanoidRootPart")
                if hrp then
                    if not anchorPosition then
                        anchorPosition = hrp.Position
                    end
                    
                    local distance = (hrp.Position - anchorPosition).Magnitude
                    
                    if distance > 3 then
                        hrp.CFrame = CFrame.new(anchorPosition)
                        local hum = player.Character:FindFirstChildOfClass("Humanoid")
                        if hum then
                            hum:ChangeState(Enum.HumanoidStateType.GettingUp)
                        end
                    end
                    
                    anchorPosition = anchorPosition:Lerp(hrp.Position, 0.1)
                end
            end
        end)
    else
        if anchorConnection then
            anchorConnection:Disconnect()
            anchorConnection = nil
        end
        anchorPosition = nil
    end
end)

player.CharacterAdded:Connect(function()
    if anchorAtivo then
        task.wait(0.5)
        if player.Character and player.Character:FindFirstChild("HumanoidRootPart") then
            anchorPosition = player.Character.HumanoidRootPart.Position
        end
    end
end)

