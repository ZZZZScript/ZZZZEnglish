-- ANIMAÇÕES DO ÍCONE
-- ============================================================

task.spawn(function()
    local angle = 0
    while iconFrame and iconFrame.Parent do
        angle = (angle + 2) % 360
        iconGradient.Rotation = angle
        task.wait(0.02)
    end
end)

task.spawn(function()
    while iconFrame and iconFrame.Parent do
        TweenService:Create(iconGlow, TweenInfo.new(1, Enum.EasingStyle.Sine), {
            BackgroundTransparency = 0.5
        }):Play()
        task.wait(1)
        TweenService:Create(iconGlow, TweenInfo.new(1, Enum.EasingStyle.Sine), {
            BackgroundTransparency = 0.8
        }):Play()
        task.wait(1)
    end
end)

-- ============================================================
-- ARRASTAR ÍCONE (FUNCIONAL)
-- ============================================================
local iconDragging = false
local iconDragStart = nil
local iconStartPos = nil

iconButton.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 then
        iconDragging = true
        iconDragStart = input.Position
        iconStartPos = iconFrame.Position
    end
end)

iconButton.InputEnded:Connect(function()
    iconDragging = false
end)

UserInputService.InputChanged:Connect(function(input)
    if iconDragging and input.UserInputType == Enum.UserInputType.MouseMovement then
        local delta = input.Position - iconDragStart
        iconFrame.Position = UDim2.new(
            iconStartPos.X.Scale,
            iconStartPos.X.Offset + delta.X,
            iconStartPos.Y.Scale,
            iconStartPos.Y.Offset + delta.Y
        )
    end
end)

-- ============================================================
-- FUNÇÕES DO MENU
-- ============================================================
local menuVisible = true

iconButton.MouseButton1Click:Connect(function()
    menuVisible = not menuVisible
    MainContainer.Visible = menuVisible
    
    TweenService:Create(iconFrame, TweenInfo.new(0.1), {
        Size = UDim2.new(0, iconSize - 8, 0, iconSize - 8)
    }):Play()
    task.wait(0.08)
    TweenService:Create(iconFrame, TweenInfo.new(0.08), {
        Size = UDim2.new(0, iconSize, 0, iconSize)
    }):Play()
    
    iconText.TextColor3 = menuVisible and PINK or Color3.fromRGB(150, 80, 30)
end)

closeBtn.MouseButton1Click:Connect(function()
    MainContainer.Visible = false
    menuVisible = false
    iconText.TextColor3 = Color3.fromRGB(150, 80, 30)
end)

