-- Função criar toggle
local function criarToggle(texto, y)
    local frame = Instance.new("Frame")
    frame.Size = UDim2.new(1, 0, 0, 45)
    frame.Position = UDim2.new(0, 0, 0, y)
    frame.BackgroundColor3 = Color3.fromRGB(35, 35, 45)
    frame.Parent = scroll
    Instance.new("UICorner", frame).CornerRadius = UDim.new(0, 8)
    
    local label = Instance.new("TextLabel")
    label.Size = UDim2.new(0.6, 0, 1, 0)
    label.Position = UDim2.new(0, 10, 0, 0)
    label.Text = texto
    label.Font = Enum.Font.GothamBold
    label.TextSize = 12
    label.TextColor3 = Color3.fromRGB(255, 255, 255)
    label.BackgroundTransparency = 1
    label.TextXAlignment = Enum.TextXAlignment.Left
    label.Parent = frame
    
    local toggle = Instance.new("TextButton")
    toggle.Size = UDim2.new(0, 50, 0, 28)
    toggle.Position = UDim2.new(1, -60, 0.5, -14)
    toggle.Text = "OFF"
    toggle.Font = Enum.Font.GothamBold
    toggle.TextSize = 11
    toggle.TextColor3 = Color3.fromRGB(255, 100, 100)
    toggle.BackgroundColor3 = Color3.fromRGB(60, 60, 75)
    toggle.Parent = frame
    Instance.new("UICorner", toggle).CornerRadius = UDim.new(0, 6)
    
    local ativo = false
    
    toggle.MouseButton1Click:Connect(function()
        ativo = not ativo
        if ativo then
            toggle.Text = "ON"
            toggle.TextColor3 = Color3.fromRGB(100, 255, 100)
            toggle.BackgroundColor3 = Color3.fromRGB(80, 120, 80)
        else
            toggle.Text = "OFF"
            toggle.TextColor3 = Color3.fromRGB(255, 100, 100)
            toggle.BackgroundColor3 = Color3.fromRGB(60, 60, 75)
        end
    end)
    
    return {frame = frame, get = function() return ativo end, set = function(v) ativo = v; if v then toggle.Text = "ON"; toggle.TextColor3 = Color3.fromRGB(100, 255, 100); toggle.BackgroundColor3 = Color3.fromRGB(80, 120, 80) else toggle.Text = "OFF"; toggle.TextColor3 = Color3.fromRGB(255, 100, 100); toggle.BackgroundColor3 = Color3.fromRGB(60, 60, 75) end end}
end

