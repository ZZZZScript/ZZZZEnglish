-- ========== FUNÇÃO PARA CRIAR PLATAFORMA (100x30) ==========
local function criarPlataforma()
    -- Destruir plataforma antiga se existir
    if plataforma then
        plataforma:Destroy()
        plataforma = nil
    end
    
    local character = player.Character
    if not character then return end
    
    local hrp = character:FindFirstChild("HumanoidRootPart")
    if not hrp then return end
    
    -- Criar plataforma GRANDE (Largura 100, Altura 30, Profundidade 100)
    local platform = Instance.new("Part")
    platform.Size = Vector3.new(100, 30, 100)  -- Largura 100, Altura 30, Profundidade 100
    platform.Position = hrp.Position - Vector3.new(0, 15, 0)  -- Centralizar a plataforma abaixo
    platform.Anchored = true
    platform.CanCollide = true
    platform.Transparency = 0.7
    platform.BrickColor = BrickColor.new("Bright blue")
    platform.Material = Enum.Material.SmoothPlastic
    platform.Name = "AntiFallPlatform"
    platform.Parent = workspace
    
    -- Efeito de brilho
    local glow = Instance.new("SelectionBox")
    glow.Adornee = platform
    glow.Color3 = Color3.fromRGB(0, 150, 255)
    glow.LineThickness = 0.5
    glow.Transparency = 0.3
    glow.Parent = platform
    
    plataforma = platform
    print("🛡️ Plataforma anti-queda criada! Tamanho: 100x30x100")
    
    -- Atualizar posição da plataforma a cada segundo
    spawn(function()
        while plataformaAtiva and plataforma and player.Character do
            local root = player.Character:FindFirstChild("HumanoidRootPart")
            if root then
                -- Manter a plataforma centralizada abaixo do jogador
                plataforma.Position = root.Position - Vector3.new(0, 15, 0)
            end
            task.wait(0.5)
        end
    end)
end

local function removerPlataforma()
    if plataforma then
        plataforma:Destroy()
        plataforma = nil
        print("🛡️ Plataforma anti-queda removida!")
    end
end

