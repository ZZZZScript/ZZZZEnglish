-- TESTE PARA VER RESPOSTA DO SERVIDOR
local Players = game:GetService("Players")
local player = Players.LocalPlayer

local url = "https://discord-node-bot--joaolmadureira2.replit.app/check?id=" .. player.UserId

print("🔍 Verificando ID: " .. player.UserId)
print("🔗 URL: " .. url)

local success, response = pcall(function()
    return game:HttpGet(url)
end)

if success then
    print("📥 RESPOSTA COMPLETA: [" .. response .. "]")
    print("📏 Tamanho: " .. #response .. " caracteres")
    print("🔤 Tipo: " .. type(response))
    
    -- Mostra cada caractere
    print("📋 Caracteres:")
    for i = 1, #response do
        print("  " .. i .. ": " .. string.byte(response, i) .. " -> " .. string.sub(response, i, i))
    end
else
    print("❌ ERRO: " .. tostring(response))
end