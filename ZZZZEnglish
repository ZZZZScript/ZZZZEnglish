-- ========== FUNÇÃO CRIAR CARD COM TOGGLE ==========
local function criarCard(icone, texto, y)
    local card = Instance.new("Frame")
    card.Size = UDim2.new(1, 0, 0, 52)
    card.Position = UDim2.new(0, 0, 0, y)
    card.BackgroundColor3 = corCard
    card.Parent = scroll
    Instance.new("UICorner", card).CornerRadius = UDim.new(0, 10)
    
    local iconeLab = Instance.new("TextLabel")
    iconeLab.Size = UDim2.new(0, 38, 0, 38)
    iconeLab.Position = UDim2.new(0, 10, 0.5, -19)
    iconeLab.Text = icone
    iconeLab.Font = Enum.Font.Gotham
    iconeLab.TextSize = 22
    iconeLab.TextColor3 = corAzul
    iconeLab.BackgroundTransparency = 1
    iconeLab.Parent = card
    
    local textoLab = Instance.new("TextLabel")
    textoLab.Size = UDim2.new(0, 140, 0, 25)
    textoLab.Position = UDim2.new(0, 55, 0.5, -12)
    textoLab.Text = texto
    textoLab.Font = Enum.Font.GothamBold
    textoLab.TextSize = 13
    textoLab.TextColor3 = corTextoBranco
    textoLab.BackgroundTransparency = 1
    textoLab.TextXAlignment = Enum.TextXAlignment.Left
    textoLab.Parent = card
    
    local toggle = Instance.new("TextButton")
    toggle.Size = UDim2.new(0, 48, 0, 24)
    toggle.Position = UDim2.new(1, -58, 0.5, -12)
    toggle.Text = ""
    toggle.BackgroundColor3 = Color3.fromRGB(55, 58, 70)
    toggle.Parent = card
    Instance.new("UICorner", toggle).CornerRadius = UDim.new(1, 0)
    
    local bola = Instance.new("Frame")
    bola.Size = UDim2.new(0, 18, 0, 18)
    bola.Position = UDim2.new(0, 4, 0.5, -9)
    bola.BackgroundColor3 = corTextoBranco
    bola.Parent = toggle
    Instance.new("UICorner", bola).CornerRadius = UDim.new(1, 0)
    
    local status = Instance.new("TextLabel")
    status.Size = UDim2.new(0, 32, 0, 16)
    status.Position = UDim2.new(1, -105, 0.5, -8)
    status.Text = "OFF"
    status.Font = Enum.Font.GothamBold
    status.TextSize = 8
    status.TextColor3 = Color3.fromRGB(255, 80, 80)
    status.BackgroundTransparency = 1
    status.Parent = card
    
    local ativo = false
    local callback = nil
    
    toggle.MouseButton1Click:Connect(function()
        ativo = not ativo
        if ativo then
            toggle.BackgroundColor3 = corAzul
            bola.Position = UDim2.new(1, -22, 0.5, -9)
            status.Text = "ON"
            status.TextColor3 = Color3.fromRGB(80, 255, 80)
        else
            toggle.BackgroundColor3 = Color3.fromRGB(55, 58, 70)
            bola.Position = UDim2.new(0, 4, 0.5, -9)
            status.Text = "OFF"
            status.TextColor3 = Color3.fromRGB(255, 80, 80)
        end
        if callback then callback(ativo) end
    end)
    
    return {
        onToggle = function(cb) callback = cb end
    }
end

