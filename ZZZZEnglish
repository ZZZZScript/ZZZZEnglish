-- Função para criar toggle
local function createToggle(name, yPos, key)
    local row = Instance.new("Frame")
    row.Size = UDim2.new(0.94, 0, 0, 38)
    row.Position = UDim2.new(0.03, 0, 0, yPos)
    row.BackgroundColor3 = Color3.fromRGB(35, 35, 35)
    row.Parent = scroll
    Instance.new("UICorner", row).CornerRadius = UDim.new(0, 6)
    
    local label = Instance.new("TextLabel")
    label.Size = UDim2.new(0.65, 0, 1, 0)
    label.Position = UDim2.new(0, 10, 0, 0)
    label.Text = name
    label.Font = Enum.Font.GothamBold
    label.TextSize = 11
    label.TextColor3 = Color3.new(1, 1, 1)
    label.BackgroundTransparency = 1
    label.TextXAlignment = Enum.TextXAlignment.Left
    label.Parent = row
    
    local btn = Instance.new("TextButton")
    btn.Size = UDim2.new(0, 45, 0, 24)
    btn.Position = UDim2.new(1, -55, 0.5, -12)
    btn.Text = ""
    btn.BackgroundColor3 = Color3.fromRGB(80, 80, 80)
    btn.Parent = row
    Instance.new("UICorner", btn).CornerRadius = UDim.new(1, 0)
    
    local circle = Instance.new("Frame")
    circle.Size = UDim2.new(0, 18, 0, 18)
    circle.Position = UDim2.new(0, 3, 0.5, -9)
    circle.BackgroundColor3 = Color3.new(1, 1, 1)
    circle.Parent = btn
    Instance.new("UICorner", circle).CornerRadius = UDim.new(1, 0)
    
    if settings[key] then
        btn.BackgroundColor3 = Color3.fromRGB(0, 170, 0)
        circle.Position = UDim2.new(1, -21, 0.5, -9)
    end
    
    togglesUI[key] = {btn = btn, circle = circle}
    
    btn.MouseButton1Click:Connect(function()
        settings[key] = not settings[key]
        if settings[key] then
            btn.BackgroundColor3 = Color3.fromRGB(0, 170, 0)
            circle.Position = UDim2.new(1, -21, 0.5, -9)
        else
            btn.BackgroundColor3 = Color3.fromRGB(80, 80, 80)
            circle.Position = UDim2.new(0, 3, 0.5, -9)
        end
        if key == "fly" then toggleFly() end
        if key == "noclip" then toggleNoclip() end
        saveSettings()
    end)
end

