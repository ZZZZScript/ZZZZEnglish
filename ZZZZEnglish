-- Function to create a toggle switch
local function createToggleRow(name, yPos, key)
    -- Background row
    local row = Instance.new("Frame", functionsPanel)
    row.Size = UDim2.new(0.95,0,0,45)
    row.Position = UDim2.new(0.025,0,0,yPos)
    row.BackgroundColor3 = Color3.fromRGB(35,35,35)
    Instance.new("UICorner", row).CornerRadius = UDim.new(0,6)
    
    -- Text label
    local label = Instance.new("TextLabel", row)
    label.Size = UDim2.new(0.65,0,1,0)
    label.Position = UDim2.new(0,10,0,0)
    label.Text = name
    label.Font = Enum.Font.GothamBold
    label.TextSize = 12
    label.TextColor3 = Color3.new(1,1,1)
    label.BackgroundTransparency = 1
    label.TextXAlignment = Enum.TextXAlignment.Left
    
    -- Toggle button
    local toggleBtn = Instance.new("TextButton", row)
    toggleBtn.Size = UDim2.new(0,50,0,28)
    toggleBtn.Position = UDim2.new(1,-60,0.5,-14)
    toggleBtn.Text = ""
    toggleBtn.BackgroundColor3 = Color3.fromRGB(80,80,80)
    Instance.new("UICorner", toggleBtn).CornerRadius = UDim.new(1,0)
    
    -- Circle inside toggle
    local circle = Instance.new("Frame", toggleBtn)
    circle.Size = UDim2.new(0,22,0,22)
    circle.Position = UDim2.new(0,3,0.5,-11)
    circle.BackgroundColor3 = Color3.new(1,1,1)
    Instance.new("UICorner", circle).CornerRadius = UDim.new(1,0)
    
    -- Set initial state
    if settings[key] then
        toggleBtn.BackgroundColor3 = Color3.fromRGB(0,170,0)
        circle.Position = UDim2.new(1,-25,0.5,-11)
    end
    
    -- Store references
    toggles[key] = {btn = toggleBtn, circle = circle}
    
    -- Click handler
    toggleBtn.MouseButton1Click:Connect(function()
        settings[key] = not settings[key]
        
        if settings[key] then
            toggleBtn.BackgroundColor3 = Color3.fromRGB(0,170,0)
            circle.Position = UDim2.new(1,-25,0.5,-11)
        else
            toggleBtn.BackgroundColor3 = Color3.fromRGB(80,80,80)
            circle.Position = UDim2.new(0,3,0.5,-11)
        end
        
        saveSettings()
        print(name .. " is now " .. tostring(settings[key]))
    end)
    
    return row
end

