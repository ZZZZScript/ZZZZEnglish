end

-- NOCLIP
local function setNoclip(bool)
    local character = player.Character
    if character then
        for _, part in pairs(character:GetDescendants()) do
            if part:IsA("BasePart") then
                part.CanCollide = not bool
            end
        end
    end
end

-- FLY FUNCTION
local function startFly()
    if flying then return end
    
    local character = player.Character
    if not character then return end
    
    local humanoid = character:FindFirstChildOfClass("Humanoid")
    local hrp = character:FindFirstChild("HumanoidRootPart")
    
    if not humanoid or not hrp then return end
    
    flying = true
    
    humanoid.PlatformStand = true
    humanoid:SetStateEnabled(Enum.HumanoidStateType.Jumping, false)
    humanoid:SetStateEnabled(Enum.HumanoidStateType.FallingDown, false)
    
    bodyVelocity = Instance.new("BodyVelocity")
    bodyVelocity.MaxForce = Vector3.new(1e9, 1e9, 1e9)
    bodyVelocity.Velocity = Vector3.new(0, 0, 0)
    bodyVelocity.Parent = hrp
    
    bodyGyro = Instance.new("BodyGyro")
    bodyGyro.MaxTorque = Vector3.new(1e9, 1e9, 1e9)
    bodyGyro.P = 10000
    bodyGyro.CFrame = hrp.CFrame
    bodyGyro.Parent = hrp
    
    print("🕊️ Fly ON")
end

local function stopFly()
    if not flying then return end
    
    flying = false
    
    local character = player.Character
    if character then
        local humanoid = character:FindFirstChildOfClass("Humanoid")
        local hrp = character:FindFirstChild("HumanoidRootPart")
        
        if bodyVelocity then bodyVelocity:Destroy() end
        if bodyGyro then bodyGyro:Destroy() end
        bodyVelocity = nil
        bodyGyro = nil
        
        if humanoid then
            humanoid.PlatformStand = false
            humanoid:SetStateEnabled(Enum.HumanoidStateType.Jumping, true)
            humanoid:SetStateEnabled(Enum.HumanoidStateType.FallingDown, true)
        end
        
        if hrp then hrp.Velocity = Vector3.new(0, 0, 0) end
    end
    
    print("🕊️ Fly OFF")
end

-- Movimento do Fly - usa o movimento padrão do Roblox (bolinha no celular / teclado no PC)
local moveVector = Vector3.new(0, 0, 0)

-- Capturar movimento do jogador (funciona para teclado E bolinha do celular)
RunService.RenderStepped:Connect(function()
    if not settings.fly or not flying then return end
    
    local character = player.Character
    if not character then return end
    
    local humanoid = character:FindFirstChildOfClass("Humanoid")
    local hrp = character:FindFirstChild("HumanoidRootPart")
    if not hrp or not bodyVelocity then return end
    
    if humanoid then
        humanoid.PlatformStand = true
        -- Pegar a direção do movimento do joystick/teclado
        local moveDir = humanoid.MoveDirection
        local camera = workspace.CurrentCamera
        local camCF = camera.CFrame
        
        -- Converter movimento para direção baseada na câmera
        if moveDir.Magnitude > 0 then
            -- Movimento horizontal (WASD / Bolinha)
            local horizontalMove = Vector3.new(moveDir.X, 0, moveDir.Z)
            if horizontalMove.Magnitude > 0 then
                local worldDir = camCF:VectorToWorldSpace(horizontalMove)
                worldDir = Vector3.new(worldDir.X, 0, worldDir.Z).Unit
                moveVector = worldDir * flySpeed
            else
                moveVector = Vector3.new(0, 0, 0)
            end
            
            -- Movimento vertical (pulo/agachar no celular é automático)
            -- No celular, usar botões extras para cima/baixo
            if isMobile then
                -- Para mobile, manter a altura atual ou usar botões
            else
                -- PC: Space para subir, Ctrl para descer
                if UserInputService:IsKeyDown(Enum.KeyCode.Space) then
                    moveVector = moveVector + Vector3.new(0, flySpeed, 0)
                elseif UserInputService:IsKeyDown(Enum.KeyCode.LeftControl) then
                    moveVector = moveVector - Vector3.new(0, flySpeed, 0)
                end
            end
            
            bodyVelocity.Velocity = moveVector
            
            -- Olhar na direção do movimento
            if moveVector.Magnitude > 0.1 then
                local lookPos = hrp.Position + moveVector
                bodyGyro.CFrame = CFrame.lookAt(hrp.Position, lookPos)
            end
        else
            bodyVelocity.Velocity = Vector3.new(0, 0, 0)
        end
    end
end)

