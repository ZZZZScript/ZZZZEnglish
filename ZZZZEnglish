-- AUTO COLLECT MONEY FUNCTION (CORRIGIDO)
local function autoCollectMoney()
    if not settings.autoCollect then return end
    
    local character = player.Character
    if not character then return end
    
    local hrp = character:FindFirstChild("HumanoidRootPart")
    if not hrp then return end
    
    -- Procura por objetos de dinheiro no chão
    for _, obj in pairs(Workspace:GetDescendants()) do
        if obj:IsA("BasePart") and obj.Parent then
            local name = obj.Name:lower()
            -- Verifica se é dinheiro/coin
            if string.find(name, "coin") or 
               string.find(name, "money") or 
               string.find(name, "cash") or
               string.find(name, "drop") or
               obj:FindFirstChild("TouchInterest") or
               obj:FindFirstChild("ClickDetector") then
                
                pcall(function()
                    local distance = (obj.Position - hrp.Position).Magnitude
                    if distance < 8 then
                        -- Move para o dinheiro
                        hrp.CFrame = CFrame.new(obj.Position.X, hrp.Position.Y, obj.Position.Z)
                        wait(0.05)
                    end
                end)
            end
        end
    end
end

-- AUTO SELL FUNCTION (CORRIGIDO)
local function autoSell()
    if not settings.autoSell then return end
    
    local soldCount = 0
    
    -- Vende do Backpack
    if player.Backpack then
        local toolsToSell = {}
        for _, tool in pairs(player.Backpack:GetChildren()) do
            if tool:IsA("Tool") then
                for sellName, selected in pairs(selectedItems) do
                    if selected and (tool.Name == sellName or string.find(tool.Name, sellName)) then
                        table.insert(toolsToSell, tool)
                        break
                    end
                end
            end
        end
        for _, tool in pairs(toolsToSell) do
            pcall(function()
                tool:Destroy()
                soldCount = soldCount + 1
                print("💰 Sold: " .. tool.Name)
            end)
        end
    end
    
    -- Vende do Character
    if player.Character then
        local toolsToSell = {}
        for _, tool in pairs(player.Character:GetChildren()) do
            if tool:IsA("Tool") then
                for sellName, selected in pairs(selectedItems) do
                    if selected and (tool.Name == sellName or string.find(tool.Name, sellName)) then
                        table.insert(toolsToSell, tool)
                        break
                    end
                end
            end
        end
        for _, tool in pairs(toolsToSell) do
            pcall(function()
                tool:Destroy()
                soldCount = soldCount + 1
                print("💰 Sold: " .. tool.Name)
            end)
        end
    end
end

