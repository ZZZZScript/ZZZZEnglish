-- AUTO SELL FUNCTION
local function autoSell()
    if not settings.autoSell then return end
    
    for _, item in pairs(workspace:GetDescendants()) do
        if item:IsA("Model") or item:IsA("Part") or item:IsA("Tool") then
            local itemName = item.Name
            for _, sellName in pairs(autoSellList) do
                if string.find(itemName, sellName) or string.find(sellName, itemName) then
                    pcall(function()
                        if item:IsA("Tool") then
                            item:Destroy()
                        elseif item.Parent then
                            item:Destroy()
                        end
                        print("💰 Auto Sold: " .. itemName)
                    end)
                end
            end
        end
    end
    
    if player.Backpack then
        for _, tool in pairs(player.Backpack:GetChildren()) do
            for _, sellName in pairs(autoSellList) do
                if string.find(tool.Name, sellName) or string.find(sellName, tool.Name) then
                    pcall(function()
                        tool:Destroy()
                        print("💰 Auto Sold from Backpack: " .. tool.Name)
                    end)
                end
            end
        end
    end
    
    if player.Character then
        for _, tool in pairs(player.Character:GetChildren()) do
            if tool:IsA("Tool") then
                for _, sellName in pairs(autoSellList) do
                    if string.find(tool.Name, sellName) or string.find(sellName, tool.Name) then
                        pcall(function()
                            tool:Destroy()
                            print("💰 Auto Sold from Character: " .. tool.Name)
                        end)
                    end
                end
            end
        end
    end
end

-- Run Auto Sell every second
spawn(function()
    while true do
        task.wait(1)
        autoSell()
    end
end)

-- PVP FUNCTIONS

-- Auto Attack
RunService.RenderStepped:Connect(function()
    if settings.auto and player.Character and player.Character:FindFirstChild("HumanoidRootPart") then
        local hrp = player.Character.HumanoidRootPart
        local closest = nil
        local dist = math.huge
        
        for _, v in pairs(Players:GetPlayers()) do
            if v ~= player and v.Character and v.Character:FindFirstChild("HumanoidRootPart") then
                local d = (v.Character.HumanoidRootPart.Position - hrp.Position).Magnitude
                if d < dist then
                    dist = d
                    closest = v
                end
            end
        end
        
        if closest then
            hrp.Velocity = (closest.Character.HumanoidRootPart.Position - hrp.Position).Unit * 60
        end
    end
end)

-- Auto Hit
RunService.RenderStepped:Connect(function()
    if settings.hit and player.Character then
        local hum = player.Character:FindFirstChildOfClass("Humanoid")
        local hrp = player.Character:FindFirstChild("HumanoidRootPart")
        
        if hum and hrp then
            local closest = nil
            local dist = math.huge
            
            for _, v in pairs(Players:GetPlayers()) do
                if v ~= player and v.Character and v.Character:FindFirstChild("HumanoidRootPart") then
                    local d = (v.Character.HumanoidRootPart.Position - hrp.Position).Magnitude
                    if d < dist and d < 10 then
                        dist = d
                        closest = v
                    end
                end
            end
            
            if closest and closest.Character then
                hum:MoveTo(closest.Character.HumanoidRootPart.Position)
                local tool = player.Character:FindFirstChildOfClass("Tool")
                if tool then tool:Activate() end
            end
        end
    end
end)

