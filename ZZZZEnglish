        BackgroundColor3 = PINK,
        Size = UDim2.new(pct, 0, 1, 0),
        ZIndex = 8,
        Parent = sliderBg
    }, {Create("UICorner", {CornerRadius=UDim.new(1,0)})})

    local knob = Create("Frame", {
        BackgroundColor3 = Color3.new(1,1,1),
        Size = UDim2.new(0, 12, 0, 12),
        Position = UDim2.new(pct, -6, 0.5, -6),
        ZIndex = 9,
        Parent = sliderBg
    }, {
