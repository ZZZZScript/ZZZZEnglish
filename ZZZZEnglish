-- ========== TOGGLES ==========
local toggles = {}

local function criarToggle(icone, texto, y)
    local card = Instance.new("Frame")
    card.Size = UDim2.new(1, 0, 0, 34)
    card.Position = UDim2.new(0, 0, 0, y)
    card.BackgroundColor3 = cinza
    card.Parent = scroll
    Instance.new("UICorner", card).CornerRadius = UDim.new(0, 5)
    
    local i = Instance.new("TextLabel")
    i.Size = UDim2.new(0, 26, 0, 26)
    i.Position = UDim2.new(0, 6, 0.5, -13)
    i.Text = icone
    i.Font = Enum.Font.Gotham
    i.TextSize = 14
    i.TextColor3 = azul
    i.BackgroundTransparency = 1
    i.Parent = card
    
    local t = Instance.new("TextLabel")
    t.Size = UDim2.new(0, 90, 0, 18)
    t.Position = UDim2.new(0, 36, 0.5, -9)
    t.Text = texto
    t.Font = Enum.Font.GothamBold
    t.TextSize = 9
    t.TextColor3 = branco
    t.BackgroundTransparency = 1
    t.Parent = card
    
    local btn = Instance.new("TextButton")
    btn.Size = UDim2.new(0, 36, 0, 18)
    btn.Position = UDim2.new(1, -42, 0.5, -9)
    btn.Text = ""
    btn.BackgroundColor3 = Color3.fromRGB(55, 55, 65)
    btn.Parent = card
    Instance.new("UICorner", btn).CornerRadius = UDim.new(1, 0)
    
    local bola = Instance.new("Frame")
    bola.Size = UDim2.new(0, 14, 0, 14)
    bola.Position = UDim2.new(0, 2, 0.5, -7)
    bola.BackgroundColor3 = Color3.fromRGB(220, 220, 230)
    bola.Parent = btn
    Instance.new("UICorner", bola).CornerRadius = UDim.new(1, 0)
    
    local ativo = false
    local cb = nil
    
    btn.MouseButton1Click:Connect(function()
        ativo = not ativo
        if ativo then
            btn.BackgroundColor3 = azul
            bola.Position = UDim2.new(1, -16, 0.5, -7)
        else
            btn.BackgroundColor3 = Color3.fromRGB(55, 55, 65)
            bola.Position = UDim2.new(0, 2, 0.5, -7)
        end
        if cb then cb(ativo) end
    end)
    
    toggles[texto] = {onToggle = function(c) cb = c end, get = function() return ativo end}
    return toggles[texto]
end

