-- Função para encontrar o brainrot/animal mais próximo
local function findNearestBrainrot()
    local char = Player.Character
    if not char then return nil end
    local hrp = char:FindFirstChild("HumanoidRootPart")
    if not hrp then return nil end
    
    local nearest = nil
    local nearestDist = math.huge
    
    -- Procura nos plots do jogo
    local plots = Workspace:FindFirstChild("Plots")
    if plots then
        for _, plot in ipairs(plots:GetChildren()) do
            local podiums = plot:FindFirstChild("AnimalPodiums")
            if podiums then
                for _, pod in ipairs(podiums:GetChildren()) do
                    local base = pod:FindFirstChild("Base")
                    local spawn = base and base:FindFirstChild("Spawn")
                    if spawn then
                        local dist = (spawn.Position - hrp.Position).Magnitude
                        if dist < nearestDist and dist <= Values.STEAL_RADIUS then
                            nearestDist = dist
                            nearest = spawn
                        end
                    end
                end
            end
        end
    end
    
    -- Também procura por objetos com nome brainrot
    for _, obj in ipairs(Workspace:GetDescendants()) do
        if obj:IsA("BasePart") and obj.Parent then
            local nome = obj.Name:lower()
            if nome:find("brain") or nome:find("rot") or nome:find("animal") or 
               nome:find("slime") or nome:find("orb") or nome:find("pickup") then
                local dist = (obj.Position - hrp.Position).Magnitude
                if dist < nearestDist and dist <= Values.STEAL_RADIUS then
                    nearestDist = dist
                    nearest = obj
                end
            end
        end
    end
    
    return nearest, nearestDist
end

-- Função para mover o personagem até um ponto
local function moveToPoint(targetPosition, stopDistance, speed)
    local char = Player.Character
    if not char then return false end
    local hrp = char:FindFirstChild("HumanoidRootPart")
    local hum = char:FindFirstChildOfClass("Humanoid")
    if not hrp or not hum then return false end
    
    local startTime = tick()
    
    -- Loop de movimento
    while tick() - startTime < 30 do -- timeout de 30 segundos
        if not Enabled.AutoSteal then return false end
        
        local currentPos = hrp.Position
        local distance = (targetPosition - currentPos).Magnitude
        
        -- Verifica se chegou
        if distance <= stopDistance then
            hrp.AssemblyLinearVelocity = Vector3.zero
            return true
        end
        
        -- Calcula direção
        local direction = (targetPosition - currentPos).Unit
        local moveVector = Vector3.new(direction.X * speed, hrp.AssemblyLinearVelocity.Y, direction.Z * speed)
        
        -- Aplica movimento
        hrp.AssemblyLinearVelocity = moveVector
        
        -- Força o humanoid a ficar em pé
        hum:ChangeState(Enum.HumanoidStateType.Running)
        
        task.wait(0.05)
    end
    
    hrp.AssemblyLinearVelocity = Vector3.zero
    return false
end

-- Função para interagir com o brainrot
local function interactWithBrainrot(target)
    if not target then return false end
    
    local char = Player.Character
    if not char then return false end
    local hrp = char:FindFirstChild("HumanoidRootPart")
    
    if hrp and target then
        -- Tenta encontrar um ProximityPrompt
        local prompt = nil
        for _, child in ipairs(target:GetDescendants()) do
            if child:IsA("ProximityPrompt") then
                prompt = child
                break
            end
        end
        
        if prompt then
            -- Simula o prompt
            pcall(function()
                prompt:InputHoldBegin()
                task.wait(STEAL_CONFIG.HOLD_TIME)
                prompt:InputHoldEnd()
                prompt:InputEnd()
            end)
            return true
        end
        
        -- Se não tiver prompt, tenta apenas tocar no objeto
        pcall(function()
            firetouchinterest(hrp, target, 0)
            task.wait(0.1)
            firetouchinterest(hrp, target, 1)
        end)
        return true
    end
    return false
end

-- Loop principal do Auto Steal
local function startAutoStealLoop()
    if Connections.autoSteal then return end
    
    Connections.autoSteal = RunService.Heartbeat:Connect(function()
        if not Enabled.AutoSteal then return end
        if isStealing then return end
        
        local char = Player.Character
        if not char then return end
        local hrp = char:FindFirstChild("HumanoidRootPart")
        if not hrp then return end
        
        -- Encontra o brainrot mais próximo
        local target, dist = findNearestBrainrot()
        
        if target and dist <= Values.STEAL_RADIUS then
            isStealing = true
            
            -- Salva posição atual (base)
            local basePosition = hrp.Position
            local targetPosition = target.Position
            
            print("🎯 Auto Steal: Indo para o brainrot...")
            
            -- Move até o brainrot
            local moved = moveToPoint(targetPosition, STEAL_CONFIG.ARRIVAL_DISTANCE, STEAL_CONFIG.MOVE_SPEED)
            
            if moved then
                print("✅ Chegou ao brainrot! Aguardando " .. STEAL_CONFIG.HOLD_TIME .. " segundos...")
                
                -- Fica parado por 2 segundos
                task.wait(STEAL_CONFIG.HOLD_TIME)
                
                -- Interage com o brainrot
                interactWithBrainrot(target)
                
                print("🔄 Voltando para a base...")
                
                -- Move de volta para a base
                moveToPoint(basePosition, STEAL_CONFIG.BASE_DISTANCE, STEAL_CONFIG.MOVE_SPEED)
                
                print("✅ Retornou à base!")
            end
            
            isStealing = false
        end
    end)
end

local function stopAutoStealLoop()
    if Connections.autoSteal then
        Connections.autoSteal:Disconnect()
        Connections.autoSteal = nil
    end
    isStealing = false
end

