    while iconFrame and iconFrame.Parent do
        TweenService:Create(glow, TweenInfo.new(1, Enum.EasingStyle.Sine), {
            BackgroundTransparency = 0.5
        }):Play()
        task.wait(1)
        TweenService:Create(glow, TweenInfo.new(1, Enum.EasingStyle.Sine), {
            BackgroundTransparency = 0.8
        }):Play()
        task.wait(1)
    end
end)

