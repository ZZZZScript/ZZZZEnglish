-- Hover
iconFrame.MouseEnter:Connect(function()
    TweenService:Create(iconFrame, TweenInfo.new(0.2), {
        Size = UDim2.new(0, iconSize + 5, 0, iconSize + 5)
    }):Play()
    TweenService:Create(iconGlow, TweenInfo.new(0.2), {
        BackgroundTransparency = 0.4
    }):Play()
end)

iconFrame.MouseLeave:Connect(function()
    TweenService:Create(iconFrame, TweenInfo.new(0.2), {
        Size = UDim2.new(0, iconSize, 0, iconSize)
    }):Play()
    TweenService:Create(iconGlow, TweenInfo.new(0.2), {
        BackgroundTransparency = 0.7
    }):Play()
end)

-- ============================================================
-- KEYBINDS
-- ============================================================
UserInputService.InputBegan:Connect(function(input, gpe)
    if gpe then return end

    if input.KeyCode == Enum.KeyCode.Delete then
        ScreenGui:Destroy()
    elseif input.KeyCode == Enum.KeyCode.U then
        menuVisible = not menuVisible
        MainContainer.Visible = menuVisible
        iconText.TextColor3 = menuVisible and PINK or Color3.fromRGB(150, 80, 30)
    elseif input.KeyCode == KEYBINDS.SPEED then
        local newState = not Enabled.SpeedBoost
        if VisualSetters.SpeedBoost then VisualSetters.SpeedBoost(newState) end
    elseif input.KeyCode == KEYBINDS.FLOAT then
        local newState = not Enabled.Float
        if VisualSetters.Float then VisualSetters.Float(newState) end
    end
end)

