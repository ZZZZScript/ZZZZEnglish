-- ========== AUTO COLLECT MONEY (COLETA REMOTA SEM MOVER PERSONAGEM) ==========
local collectActive = false

-- Função para coletar dinheiro remotamente
local function autoCollectMoneyFunction()
    if not collectActive then return end
    
    local coletados = 0
    
    -- Procurar por objetos de dinheiro no workspace
    for _, obj in pairs(workspace:GetDescendants()) do
        local nome = obj.Name:lower()
        
        -- Verificar se é um item de dinheiro
        local isMoney = false
        if obj:IsA("BasePart") or obj:IsA("Model") then
            if string.find(nome, "coin") or 
               string.find(nome, "money") or 
               string.find(nome, "cash") or 
               string.find(nome, "drop") or
               string.find(nome, "brainrot") then
                isMoney = true
            end
        end
        
        if isMoney then
            pcall(function()
                -- Método 1: Tentar usar FireServer em remotes
                local remotes = {
                    ReplicatedStorage:FindFirstChild("Collect"),
                    ReplicatedStorage:FindFirstChild("Claim"),
                    ReplicatedStorage:FindFirstChild("Pickup"),
                    ReplicatedStorage:FindFirstChild("CollectMoney"),
                    ReplicatedStorage:FindFirstChild("GrabMoney"),
                    ReplicatedStorage:FindFirstChild("TakeMoney"),
                    ReplicatedStorage:FindFirstChild("GetMoney"),
                }
                
                for _, remote in pairs(remotes) do
                    if remote then
                        remote:FireServer(obj)
                        coletados = coletados + 1
                    end
                end
                
                -- Método 2: Destruir o objeto diretamente (se for apenas visual)
                if obj:IsA("BasePart") then
                    obj:Destroy()
                    coletados = coletados + 1
                elseif obj:IsA("Model") then
                    obj:Destroy()
                    coletados = coletados + 1
                end
            end)
        end
    end
    
    if coletados > 0 then
        print("💰 Coletados " .. coletados .. " itens remotamente")
    end
end

-- Loop de coleta a cada 0.3 segundos (mais rápido)
spawn(function()
    while true do
        task.wait(0.3)
        autoCollectMoneyFunction()
    end
end)

