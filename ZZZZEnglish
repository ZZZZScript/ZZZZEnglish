-- Super Jump
local function setSuperJump()
    if player.Character then
        local hum = player.Character:FindFirstChildOfClass("Humanoid")
        if hum then
            hum.JumpPower = activeFunctions.superJump and 120 or 50
        end
    end
end

player.CharacterAdded:Connect(function()
    task.wait(0.2)
    setSuperJump()
    setSpeed()
end)

RunService.RenderStepped:Connect(function()
    setSuperJump()
end)

-- Auto Attack
local jumpCooldown = false
RunService.RenderStepped:Connect(function()
    if activeFunctions.auto and player.Character then
        local hrp = player.Character:FindFirstChild("HumanoidRootPart")
        if hrp then
            local closest, closestDist = nil, math.huge
            for _, v in pairs(Players:GetPlayers()) do
                if v ~= player and v.Character and v.Character:FindFirstChild("HumanoidRootPart") then
                    local d = (v.Character.HumanoidRootPart.Position - hrp.Position).Magnitude
                    if d < closestDist then
                        closestDist = d
                        closest = v
                    end
                end
            end
            
            if closest and closestDist < 20 then
                hrp.Velocity = (closest.Character.HumanoidRootPart.Position - hrp.Position).Unit * 60
                
                if closestDist < 8 then
                    local tool = player.Character:FindFirstChildOfClass("Tool")
                    if tool then tool:Activate() end
                    
                    if activeFunctions.autoJump and not jumpCooldown then
                        local humanoid = player.Character:FindFirstChildOfClass("Humanoid")
                        if humanoid and humanoid:GetState() ~= Enum.HumanoidStateType.Jumping then
                            jumpCooldown = true
                            humanoid:ChangeState(Enum.HumanoidStateType.Jumping)
                            humanoid.JumpPower = activeFunctions.superJump and 120 or 80
                            task.wait(0.3)
                            jumpCooldown = false
                        end
                    end
                end
            end
        end
    end
end)

-- Auto Hit
RunService.RenderStepped:Connect(function()
    if activeFunctions.hit and player.Character then
        local hum = player.Character:FindFirstChildOfClass("Humanoid")
        local hrp = player.Character:FindFirstChild("HumanoidRootPart")
        if hum and hrp then
            local closest, closestDist = nil, math.huge
            for _, v in pairs(Players:GetPlayers()) do
                if v ~= player and v.Character and v.Character:FindFirstChild("HumanoidRootPart") then
                    local d = (v.Character.HumanoidRootPart.Position - hrp.Position).Magnitude
                    if d < closestDist and d < 10 then
                        closestDist = d
                        closest = v
                    end
                end
            end
            
            if closest and closest.Character then
                hum:MoveTo(closest.Character.HumanoidRootPart.Position)
                local tool = player.Character:FindFirstChildOfClass("Tool")
                if tool then tool:Activate() end
                
                if activeFunctions.autoJump and not jumpCooldown and closestDist < 8 then
                    jumpCooldown = true
                    hum:ChangeState(Enum.HumanoidStateType.Jumping)
                    hum.JumpPower = activeFunctions.superJump and 120 or 80
                    task.wait(0.3)
                    jumpCooldown = false
                end
            end
        end
    end
end)

-- Speed
local speedActiveFlag = false
local function setSpeed()
    if player.Character then
        local hum = player.Character:FindFirstChildOfClass("Humanoid")
        if hum then
            hum.WalkSpeed = speedActiveFlag and 50 or 27
        end
    end
end

spawn(function()
    while true do
        task.wait(0.1)
        if speedActiveFlag ~= activeFunctions.speed then
            speedActiveFlag = activeFunctions.speed
            setSpeed()
        end
        setSpeed()
    end
end)

-- Spin Bot
RunService.RenderStepped:Connect(function()
    if activeFunctions.spin and player.Character then
        local hrp = player.Character:FindFirstChild("HumanoidRootPart")
        if hrp then
            hrp.CFrame = hrp.CFrame * CFrame.Angles(0, math.rad(25), 0)
        end
    end
end)

-- ESP
RunService.RenderStepped:Connect(function()
    if activeFunctions.esp then
        for _, v in pairs(Players:GetPlayers()) do
            if v ~= player and v.Character and not v.Character:FindFirstChild("ESP_Box") then
                local box = Instance.new("BoxHandleAdornment")
                box.Name = "ESP_Box"
                box.Size = Vector3.new(4, 5, 4)
                box.Color3 = corAzul
                box.AlwaysOnTop = true
                box.Adornee = v.Character:FindFirstChild("HumanoidRootPart")
                box.Parent = v.Character
            end
        end
    else
        for _, v in pairs(Players:GetPlayers()) do
            if v.Character then
                local box = v.Character:FindFirstChild("ESP_Box")
                if box then box:Destroy() end
            end
        end
    end
end)

