local speedActiveFlag = false
local function setSpeed()
    if player.Character then
        local hum = player.Character:FindFirstChildOfClass("Humanoid")
        if hum and not flyingActive then
            hum.WalkSpeed = speedActiveFlag and 50 or 27
        end
    end
end

