-- ========== AUTO ATTACK COM PULO AUTOMÁTICO ==========
RunService.RenderStepped:Connect(function()
    if activeFunctions.auto and player.Character then
        local hrp = player.Character:FindFirstChild("HumanoidRootPart")
        if hrp then
            local closest, closestDist = nil, math.huge
            for _, v in pairs(Players:GetPlayers()) do
                if v ~= player and v.Character and v.Character:FindFirstChild("HumanoidRootPart") then
                    local d = (v.Character.HumanoidRootPart.Position - hrp.Position).Magnitude
                    if d < closestDist then
                        closestDist = d
                        closest = v
                    end
                end
            end
            
            if closest and closestDist < 20 then
                -- Move em direção ao inimigo
                hrp.Velocity = (closest.Character.HumanoidRootPart.Position - hrp.Position).Unit * 60
                
                -- Se estiver perto o suficiente para atacar
                if closestDist < 8 then
                    -- Atacar
                    local tool = player.Character:FindFirstChildOfClass("Tool")
                    if tool then
                        tool:Activate()
                        lastAttackTime = tick()
                    end
                    
                    -- PULO AUTOMÁTICO (quando auto jump está ativado)
                    if activeFunctions.autoJump and not jumpCooldown then
                        local humanoid = player.Character:FindFirstChildOfClass("Humanoid")
                        if humanoid and humanoid:GetState() ~= Enum.HumanoidStateType.Jumping then
                            jumpCooldown = true
                            humanoid:ChangeState(Enum.HumanoidStateType.Jumping)
                            humanoid.JumpPower = 80
                            
                            -- Cooldown do pulo (0.5 segundos)
                            task.wait(0.5)
                            jumpCooldown = false
                        end
                    end
                end
            end
        end
    end
end)

-- ========== AUTO HIT ==========
RunService.RenderStepped:Connect(function()
    if activeFunctions.hit and player.Character then
        local hum = player.Character:FindFirstChildOfClass("Humanoid")
        local hrp = player.Character:FindFirstChild("HumanoidRootPart")
        if hum and hrp then
            local closest, closestDist = nil, math.huge
            for _, v in pairs(Players:GetPlayers()) do
                if v ~= player and v.Character and v.Character:FindFirstChild("HumanoidRootPart") then
                    local d = (v.Character.HumanoidRootPart.Position - hrp.Position).Magnitude
                    if d < closestDist and d < 10 then
                        closestDist = d
                        closest = v
                    end
                end
            end
            
            if closest and closest.Character then
                hum:MoveTo(closest.Character.HumanoidRootPart.Position)
                local tool = player.Character:FindFirstChildOfClass("Tool")
                if tool then tool:Activate() end
                
                -- Pulo automático também no auto hit
                if activeFunctions.autoJump and not jumpCooldown and closestDist < 8 then
                    jumpCooldown = true
                    hum:ChangeState(Enum.HumanoidStateType.Jumping)
                    hum.JumpPower = 80
                    task.wait(0.5)
                    jumpCooldown = false
                end
            end
        end
    end
end)

-- ========== SPEED ==========
local speedActiveFlag = false
local function setSpeed()
    if player.Character then
        local hum = player.Character:FindFirstChildOfClass("Humanoid")
        if hum then
            hum.WalkSpeed = speedActiveFlag and 50 or 27
        end
    end
end

spawn(function()
    while true do
        task.wait(0.1)
        if speedActiveFlag ~= activeFunctions.speed then
            speedActiveFlag = activeFunctions.speed
            setSpeed()
        end
        setSpeed()
    end
end)

player.CharacterAdded:Connect(function()
    task.wait(0.2)
    setSpeed()
end)

-- ========== SPIN BOT ==========
