local function trocarAba(nome)
    for _, scroll in pairs(conteudos) do
        scroll.Visible = false
    end
    conteudos[nome].Visible = true
    
    for nomeAba, btn in pairs(botoesAbas) do
        btn.BackgroundColor3 = cardBg
        btn.TextColor3 = textoClaro
    end
    botoesAbas[nome].BackgroundColor3 = azul
    botoesAbas[nome].TextColor3 = textoBranco
end

for nome, btn in pairs(botoesAbas) do
    btn.MouseButton1Click:Connect(function()
        trocarAba(nome)
    end)
end

