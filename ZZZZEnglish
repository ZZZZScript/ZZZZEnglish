-- FUNÇÃO TOGGLE
local togglesList = {}

local function addToggle(icone, texto, y)
    local card = Instance.new("Frame")
    card.Size = UDim2.new(1, 0, 0, 36)
    card.Position = UDim2.new(0, 0, 0, y)
    card.BackgroundColor3 = cinzaCard
    card.Parent = scroll
    Instance.new("UICorner", card).CornerRadius = UDim.new(0, 6)
    
    local iconLabel = Instance.new("TextLabel")
    iconLabel.Size = UDim2.new(0, 28, 0, 28)
    iconLabel.Position = UDim2.new(0, 6, 0.5, -14)
    iconLabel.Text = icone
    iconLabel.Font = Enum.Font.Gotham
    iconLabel.TextSize = 16
    iconLabel.TextColor3 = azulToggle
    iconLabel.BackgroundTransparency = 1
    iconLabel.Parent = card
    
    local textLabel = Instance.new("TextLabel")
    textLabel.Size = UDim2.new(0, 100, 0, 20)
    textLabel.Position = UDim2.new(0, 38, 0.5, -10)
    textLabel.Text = texto
    textLabel.Font = Enum.Font.GothamBold
    textLabel.TextSize = 10
    textLabel.TextColor3 = branco
    textLabel.BackgroundTransparency = 1
    textLabel.TextXAlignment = Enum.TextXAlignment.Left
    textLabel.Parent = card
    
    local toggleBtn = Instance.new("TextButton")
    toggleBtn.Size = UDim2.new(0, 38, 0, 20)
    toggleBtn.Position = UDim2.new(1, -45, 0.5, -10)
    toggleBtn.Text = ""
    toggleBtn.BackgroundColor3 = cinzaToggle
    toggleBtn.Parent = card
    Instance.new("UICorner", toggleBtn).CornerRadius = UDim.new(1, 0)
    
    local bola = Instance.new("Frame")
    bola.Size = UDim2.new(0, 16, 0, 16)
    bola.Position = UDim2.new(0, 2, 0.5, -8)
    bola.BackgroundColor3 = Color3.fromRGB(220, 220, 230)
    bola.Parent = toggleBtn
    Instance.new("UICorner", bola).CornerRadius = UDim.new(1, 0)
    
    local ativo = false
    local callback = nil
    
    toggleBtn.MouseButton1Click:Connect(function()
        ativo = not ativo
        if ativo then
            toggleBtn.BackgroundColor3 = azulToggle
            bola.Position = UDim2.new(1, -18, 0.5, -8)
        else
            toggleBtn.BackgroundColor3 = cinzaToggle
            bola.Position = UDim2.new(0, 2, 0.5, -8)
        end
        if callback then callback(ativo) end
    end)
    
    togglesList[texto] = {
        onToggle = function(cb) callback = cb end,
        get = function() return ativo end
    }
    
    return togglesList[texto]
end

