local function criarCard(icone, titulo, desc, yPos, parent, temToggle)
    local card = Instance.new("Frame")
    card.Size = UDim2.new(1, 0, 0, 65)
    card.Position = UDim2.new(0, 0, 0, yPos)
    card.BackgroundColor3 = corCard
    card.Parent = parent
    Instance.new("UICorner", card).CornerRadius = UDim.new(0, 12)
    
    local iconLabel = Instance.new("TextLabel")
    iconLabel.Size = UDim2.new(0, 45, 0, 45)
    iconLabel.Position = UDim2.new(0, 12, 0.5, -22.5)
    iconLabel.Text = icone
    iconLabel.Font = Enum.Font.Gotham
    iconLabel.TextSize = 26
    iconLabel.TextColor3 = corAzul
    iconLabel.BackgroundTransparency = 1
    iconLabel.Parent = card
    
    local titleCard = Instance.new("TextLabel")
    titleCard.Size = UDim2.new(0, 180, 0, 22)
    titleCard.Position = UDim2.new(0, 65, 0, 12)
    titleCard.Text = titulo
    titleCard.Font = Enum.Font.GothamBold
    titleCard.TextSize = 13
    titleCard.TextColor3 = corTextoBranco
    titleCard.BackgroundTransparency = 1
    titleCard.TextXAlignment = Enum.TextXAlignment.Left
    titleCard.Parent = card
    
    local descCard = Instance.new("TextLabel")
    descCard.Size = UDim2.new(0, 200, 0, 18)
    descCard.Position = UDim2.new(0, 65, 0, 35)
    descCard.Text = desc
    descCard.Font = Enum.Font.Gotham
    descCard.TextSize = 9
    descCard.TextColor3 = corTextoClaro
    descCard.BackgroundTransparency = 1
    descCard.TextXAlignment = Enum.TextXAlignment.Left
    descCard.Parent = card
    
    if temToggle then
        local toggleBtn = Instance.new("TextButton")
        toggleBtn.Size = UDim2.new(0, 50, 0, 28)
        toggleBtn.Position = UDim2.new(1, -60, 0.5, -14)
        toggleBtn.Text = ""
        toggleBtn.BackgroundColor3 = Color3.fromRGB(55, 58, 70)
        toggleBtn.Parent = card
        Instance.new("UICorner", toggleBtn).CornerRadius = UDim.new(1, 0)
        
        local circle = Instance.new("Frame")
        circle.Size = UDim2.new(0, 22, 0, 22)
        circle.Position = UDim2.new(0, 4, 0.5, -11)
        circle.BackgroundColor3 = corTextoBranco
        circle.Parent = toggleBtn
        Instance.new("UICorner", circle).CornerRadius = UDim.new(1, 0)
        
        local statusLabel = Instance.new("TextLabel")
        statusLabel.Size = UDim2.new(0, 40, 0, 20)
        statusLabel.Position = UDim2.new(1, -115, 0.5, -10)
        statusLabel.Text = "OFF"
        statusLabel.Font = Enum.Font.GothamBold
        statusLabel.TextSize = 9
        statusLabel.TextColor3 = Color3.fromRGB(255, 80, 80)
        statusLabel.BackgroundTransparency = 1
        statusLabel.Parent = card
        
        local ativo = false
        local callback = nil
        
        toggleBtn.MouseButton1Click:Connect(function()
            ativo = not ativo
            if ativo then
                toggleBtn.BackgroundColor3 = corAzul
                circle.Position = UDim2.new(1, -26, 0.5, -11)
                statusLabel.Text = "ON"
                statusLabel.TextColor3 = Color3.fromRGB(80, 255, 80)
            else
                toggleBtn.BackgroundColor3 = Color3.fromRGB(55, 58, 70)
                circle.Position = UDim2.new(0, 4, 0.5, -11)
                statusLabel.Text = "OFF"
                statusLabel.TextColor3 = Color3.fromRGB(255, 80, 80)
            end
            if callback then callback(ativo) end
        end)
        
        return {
            setAtivo = function(val)
                ativo = val
                if ativo then
                    toggleBtn.BackgroundColor3 = corAzul
                    circle.Position = UDim2.new(1, -26, 0.5, -11)
                    statusLabel.Text = "ON"
                    statusLabel.TextColor3 = Color3.fromRGB(80, 255, 80)
                else
                    toggleBtn.BackgroundColor3 = Color3.fromRGB(55, 58, 70)
                    circle.Position = UDim2.new(0, 4, 0.5, -11)
                    statusLabel.Text = "OFF"
                    statusLabel.TextColor3 = Color3.fromRGB(255, 80, 80)
                end
                if callback then callback(ativo) end
            end,
            onToggle = function(cb) callback = cb end
        }
    else
        return card
    end
end

