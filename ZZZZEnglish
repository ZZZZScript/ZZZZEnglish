-- Super Jump
local function applySuperJump()
    if player.Character then
        local hum = player.Character:FindFirstChildOfClass("Humanoid")
        if hum then hum.JumpPower = pvp.superJump and 120 or 50 end
    end
end

player.CharacterAdded:Connect(function() task.wait(0.2); applySuperJump() end)
RunService.RenderStepped:Connect(applySuperJump)

-- Auto Attack
RunService.RenderStepped:Connect(function()
    if pvp.auto and player.Character then
        local root = player.Character:FindFirstChild("HumanoidRootPart")
        if root then
            local closest, bestDist = nil, math.huge
            for _, v in pairs(Players:GetPlayers()) do
                if v ~= player and v.Character and v.Character:FindFirstChild("HumanoidRootPart") then
                    local d = (v.Character.HumanoidRootPart.Position - root.Position).Magnitude
                    if d < bestDist then bestDist, closest = d, v end
                end
            end
            if closest and bestDist < 20 then
                root.Velocity = (closest.Character.HumanoidRootPart.Position - root.Position).Unit * 60
                if bestDist < 8 then
                    local tool = player.Character:FindFirstChildOfClass("Tool")
                    if tool then tool:Activate() end
                end
            end
        end
    end
end)

-- Auto Hit
RunService.RenderStepped:Connect(function()
    if pvp.hit and player.Character then
        local hum = player.Character:FindFirstChildOfClass("Humanoid")
        local root = player.Character:FindFirstChild("HumanoidRootPart")
        if hum and root then
            local closest, bestDist = nil, math.huge
            for _, v in pairs(Players:GetPlayers()) do
                if v ~= player and v.Character and v.Character:FindFirstChild("HumanoidRootPart") then
                    local d = (v.Character.HumanoidRootPart.Position - root.Position).Magnitude
                    if d < bestDist and d < 10 then bestDist, closest = d, v end
                end
            end
            if closest then
                hum:MoveTo(closest.Character.HumanoidRootPart.Position)
                local tool = player.Character:FindFirstChildOfClass("Tool")
                if tool then tool:Activate() end
            end
        end
    end
end)

-- Spin Bot
RunService.RenderStepped:Connect(function()
    if pvp.spin and player.Character then
        local root = player.Character:FindFirstChild("HumanoidRootPart")
        if root then root.CFrame = root.CFrame * CFrame.Angles(0, math.rad(25), 0) end
    end
end)

-- ESP
RunService.RenderStepped:Connect(function()
    if pvp.esp then
        for _, v in pairs(Players:GetPlayers()) do
            if v ~= player and v.Character and not v.Character:FindFirstChild("ESP_Box") then
                local box = Instance.new("BoxHandleAdornment")
                box.Name = "ESP_Box"
                box.Size = Vector3.new(4, 5, 4)
                box.Color3 = azulToggle
                box.AlwaysOnTop = true
                box.Adornee = v.Character:FindFirstChild("HumanoidRootPart")
                box.Parent = v.Character
            end
        end
    else
        for _, v in pairs(Players:GetPlayers()) do
            if v.Character then
                local box = v.Character:FindFirstChild("ESP_Box")
                if box then box:Destroy() end
            end
        end
    end
end)

