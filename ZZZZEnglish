-- ========== AUTO COLLECT MONEY (CORRIGIDO - COLETA DINHEIRO DO CHÃO) ==========
local collectActive = false

-- Função para coletar dinheiro do chão
local function coletarDinheiro()
    if not collectActive then return end
    
    local character = player.Character
    if not character then return end
    
    local hrp = character:FindFirstChild("HumanoidRootPart")
    if not hrp then return end
    
    local coletados = 0
    
    -- Procurar por dinheiro/coins no workspace
    for _, obj in pairs(workspace:GetDescendants()) do
        if obj:IsA("BasePart") then
            local nome = obj.Name:lower()
            -- Verificar se é dinheiro/coin (nomes comuns)
            if string.find(nome, "coin") or 
               string.find(nome, "money") or 
               string.find(nome, "cash") or 
               string.find(nome, "drop") or
               string.find(nome, "brainrot") or
               obj:FindFirstChild("TouchInterest") then
                
                pcall(function()
                    -- Teleportar o dinheiro para perto do jogador
                    local distancia = (obj.Position - hrp.Position).Magnitude
                    if distancia > 3 then
                        -- Mover para perto do jogador
                        obj.CFrame = hrp.CFrame + Vector3.new(0, 1, 0)
                    end
                    
                    -- Se estiver muito perto, coletar
                    if distancia < 5 then
                        -- Remover sons e efeitos
                        local sound = obj:FindFirstChildWhichIsA("Sound")
                        if sound then sound:Destroy() end
                        
                        local billboard = obj:FindFirstChildWhichIsA("BillboardGui")
                        if billboard then billboard:Destroy() end
                        
                        -- Destruir o objeto
                        obj:Destroy()
                        coletados = coletados + 1
                    end
                end)
            end
        end
        
        -- Verificar por modelos de dinheiro
        if obj:IsA("Model") then
            local nome = obj.Name:lower()
            if string.find(nome, "coin") or string.find(nome, "money") or string.find(nome, "cash") then
                pcall(function()
                    local primary = obj.PrimaryPart or obj:FindFirstChildWhichIsA("BasePart")
                    if primary then
                        local distancia = (primary.Position - hrp.Position).Magnitude
                        if distancia > 3 then
                            primary.CFrame = hrp.CFrame + Vector3.new(0, 1, 0)
                        end
                        
                        if distancia < 5 then
                            -- Remover sons e efeitos
                            for _, sound in pairs(obj:GetDescendants()) do
                                if sound:IsA("Sound") then
                                    sound:Destroy()
                                end
                                if sound:IsA("BillboardGui") then
                                    sound:Destroy()
                                end
                            end
                            obj:Destroy()
                            coletados = coletados + 1
                        end
                    end
                end)
            end
        end
    end
end

-- Loop de coleta (a cada 0.2 segundos)
spawn(function()
    while true do
        task.wait(0.2)
        coletarDinheiro()
    end
end)

