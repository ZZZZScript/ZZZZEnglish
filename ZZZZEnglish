-- Load settings
local function loadSettings()
    local data = player:GetAttribute(SAVE_KEY)
    if data then
        settings.auto = string.find(data, '"auto":true') and true or false
        settings.esp = string.find(data, '"esp":true') and true or false
        settings.spin = string.find(data, '"spin":true') and true or false
        settings.resetP = string.find(data, '"resetP":true') and true or false
        settings.jump = string.find(data, '"jump":true') and true or false
        settings.hit = string.find(data, '"hit":true') and true or false
        settings.speed = string.find(data, '"speed":true') and true or false
        settings.autoSell = string.find(data, '"autoSell":true') and true or false
        
        -- Load selected items
        local selectedData = string.match(data, '"selectedItems":"(.-)"')
        if selectedData then
            -- Reset all selections first
            for item, _ in pairs(selectedItems) do
                selectedItems[item] = false
            end
            -- Load saved selections
            for item in string.gmatch(selectedData, "([^,]+)") do
                if selectedItems[item] ~= nil then
                    selectedItems[item] = true
                end
            end
        end
        print("✅ Loaded")
    end
end

-- Save settings
local function saveSettings()
    local selectedStr = ""
    for item, selected in pairs(selectedItems) do
        if selected then
            selectedStr = selectedStr .. item .. ","
        end
    end
    -- Remove trailing comma
    if selectedStr ~= "" then
        selectedStr = selectedStr:sub(1, -2)
    end
    
    local json = '{"auto":'..tostring(settings.auto)..
                 ',"esp":'..tostring(settings.esp)..
                 ',"spin":'..tostring(settings.spin)..
                 ',"resetP":'..tostring(settings.resetP)..
                 ',"jump":'..tostring(settings.jump)..
                 ',"hit":'..tostring(settings.hit)..
                 ',"speed":'..tostring(settings.speed)..
                 ',"autoSell":'..tostring(settings.autoSell)..
                 ',"selectedItems":"'..selectedStr..'"}'
    player:SetAttribute(SAVE_KEY, json)
    print("💾 Saved!")
end

