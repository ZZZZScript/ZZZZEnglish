local CoreGui = game:GetService("CoreGui")
local screenGui = CoreGui:FindFirstChild("ChironDuels")

if screenGui then
    print("✅ ScreenGui encontrado!")
    for _, child in pairs(screenGui:GetChildren()) do
        print("  - " .. child.Name .. " (" .. child.ClassName .. ")")
    end
else
    print("❌ ScreenGui 'ChironDuels' não encontrado!")
end