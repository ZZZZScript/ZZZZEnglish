-- ========== LOOP DO ANCHOR (CONSTANTE) ==========
spawn(function()
    while true do
        if anchorAtivo and player.Character then
            local hrp = player.Character:FindFirstChild("HumanoidRootPart")
            if hrp then
                -- Salvar posição a cada segundo
                if hrp.Position.Y > -10 then
                    savedPosition = hrp.Position
                end
                
                -- Verificar se caiu
                local humanoid = player.Character:FindFirstChildOfClass("Humanoid")
                if humanoid then
                    local state = humanoid:GetState()
                    if hrp.Position.Y < 0 or state == Enum.HumanoidStateType.FallingDown or state == Enum.HumanoidStateType.GettingUp or humanoid.Health <= 0 then
                        if not teleportCooldown and savedPosition then
                            teleportCooldown = true
                            task.wait(0.5)
                            hrp.CFrame = CFrame.new(savedPosition)
                            humanoid:ChangeState(Enum.HumanoidStateType.Running)
                            print("⚓ Teleportado de volta!")
                            task.wait(2)
                            teleportCooldown = false
                        end
                    end
                end
            end
        end
        task.wait(0.5)
    end
end)

