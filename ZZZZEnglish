-- NOCLIP FUNCTION
local function setNoclip(bool)
    if not bool then return end
    local character = player.Character
    if character then
        for _, part in pairs(character:GetDescendants()) do
            if part:IsA("BasePart") then
                part.CanCollide = false
            end
        end
    end
end

-- FLY FUNCTION (CORRIGIDO)
local function startFly()
    if flying then return end
    
    local character = player.Character
    if not character then return end
    
    local humanoid = character:FindFirstChildOfClass("Humanoid")
    local hrp = character:FindFirstChild("HumanoidRootPart")
    
    if not humanoid or not hrp then return end
    
    flying = true
    
    -- Disable gravity
    humanoid.PlatformStand = true
    humanoid:SetStateEnabled(Enum.HumanoidStateType.Jumping, false)
    
    -- Create BodyVelocity
    bodyVelocity = Instance.new("BodyVelocity")
    bodyVelocity.MaxForce = Vector3.new(100000, 100000, 100000)
    bodyVelocity.P = 10000
    bodyVelocity.Velocity = Vector3.new(0, 0, 0)
    bodyVelocity.Parent = hrp
    
    -- Fly control loop
    spawn(function()
        while flying and player.Character and hrp and hrp.Parent do
            local moveDirection = Vector3.new(0, 0, 0)
            
            -- Get camera direction
            local camera = workspace.CurrentCamera
            local camLook = camera.CFrame.LookVector
            local camRight = camera.CFrame.RightVector
            
            -- Movement
            if UserInputService:IsKeyDown(Enum.KeyCode.W) then
                moveDirection = moveDirection + Vector3.new(camLook.X, 0, camLook.Z).Unit
            end
            if UserInputService:IsKeyDown(Enum.KeyCode.S) then
                moveDirection = moveDirection - Vector3.new(camLook.X, 0, camLook.Z).Unit
            end
            if UserInputService:IsKeyDown(Enum.KeyCode.D) then
                moveDirection = moveDirection + Vector3.new(camRight.X, 0, camRight.Z).Unit
            end
            if UserInputService:IsKeyDown(Enum.KeyCode.A) then
                moveDirection = moveDirection - Vector3.new(camRight.X, 0, camRight.Z).Unit
            end
            if UserInputService:IsKeyDown(Enum.KeyCode.Space) then
                moveDirection = moveDirection + Vector3.new(0, 1, 0)
            end
            if UserInputService:IsKeyDown(Enum.KeyCode.LeftControl) then
                moveDirection = moveDirection - Vector3.new(0, 1, 0)
            end
            
            -- Set velocity
            if moveDirection.Magnitude > 0 then
                bodyVelocity.Velocity = moveDirection.Unit * flySpeed
            else
                bodyVelocity.Velocity = Vector3.new(0, 0, 0)
            end
            
            -- Update CFrame to face movement direction
            if moveDirection.Magnitude > 0 and moveDirection.Y == 0 then
                local newCFrame = CFrame.lookAt(hrp.Position, hrp.Position + Vector3.new(moveDirection.X, 0, moveDirection.Z))
                hrp.CFrame = newCFrame
            end
            
            task.wait()
        end
    end)
    
    print("🕊️ Fly ON | Speed: " .. flySpeed)
end

local function stopFly()
    if not flying then return end
    
    flying = false
    
    local character = player.Character
    if character then
        local humanoid = character:FindFirstChildOfClass("Humanoid")
        local hrp = character:FindFirstChild("HumanoidRootPart")
        
        if bodyVelocity then 
            bodyVelocity:Destroy() 
            bodyVelocity = nil
        end
        
        if humanoid then
            humanoid.PlatformStand = false
            humanoid:SetStateEnabled(Enum.HumanoidStateType.Jumping, true)
        end
        
        if hrp then
            hrp.Velocity = Vector3.new(0, 0, 0)
        end
    end
    
    print("🕊️ Fly OFF")
end

-- Toggle fly
local function toggleFly()
    settings.fly = not settings.fly
    if settings.fly then
        startFly()
    else
        stopFly()
    end
    saveSettings()
end

-- Toggle noclip
local function toggleNoclip()
    settings.noclip = not settings.noclip
    if settings.noclip then
        setNoclip(true)
        -- Keep noclip active
        spawn(function()
            while settings.noclip do
                task.wait(0.2)
                if player.Character then
                    for _, part in pairs(player.Character:GetDescendants()) do
                        if part:IsA("BasePart") then
                            part.CanCollide = false
                        end
                    end
                end
            end
        end)
    else
        if player.Character then
            for _, part in pairs(player.Character:GetDescendants()) do
                if part:IsA("BasePart") then
                    part.CanCollide = true
                end
            end
        end
    end
    saveSettings()
end

