-- ============================================================
-- ANTI RAGDOLL
-- ============================================================
local antiRagdollActive = false
local arBoostConnection = nil

local function startAntiRagdoll()
    if antiRagdollActive then return end
    antiRagdollActive = true
    
    arBoostConnection = RunService.Heartbeat:Connect(function()
        if not Enabled.AntiRagdoll then return end
        local char = Player.Character
        if not char then return end
        local hum = char:FindFirstChildOfClass("Humanoid")
        local hrp = char:FindFirstChild("HumanoidRootPart")
        
        if hum and hrp then
            local state = hum:GetState()
            local isRagdolled = state == Enum.HumanoidStateType.Physics or 
                               state == Enum.HumanoidStateType.Ragdoll or 
                               state == Enum.HumanoidStateType.FallingDown or
                               hum.PlatformStand
            
            if isRagdolled then
                hum.PlatformStand = false
                hum.Sit = false
                hum:ChangeState(Enum.HumanoidStateType.Running)
                hrp.Anchored = false
            end
            hum.AutoRotate = true
        end
    end)
end

local function stopAntiRagdoll()
    antiRagdollActive = false
    if arBoostConnection then 
        arBoostConnection:Disconnect() 
        arBoostConnection = nil 
    end
end

-- ============================================================
-- SPAM BAT
-- ============================================================
local function startSpamBat()
    if Connections.spamBat then return end
    Connections.spamBat = RunService.Heartbeat:Connect(function()
        if not Enabled.SpamBat then return end
        local bat = findBat()
        if bat then
            local now = tick()
            if now - lastBatSwing < BAT_SWING_COOLDOWN then return end
            lastBatSwing = now
            pcall(function() bat:Activate() end)
        end
    end)
end

local function stopSpamBat()
    if Connections.spamBat then 
        Connections.spamBat:Disconnect() 
        Connections.spamBat = nil 
    end
end

