local VisualSetters = {}

local function createToggle(text, key, enabledKey, callback, order)
    local btn = Instance.new("TextButton")
    btn.Size = UDim2.new(1, -10, 0, 32)
    btn.Text = text .. (key and " [" .. key .. "] " or " ") .. "OFF"
    btn.BackgroundColor3 = Color3.fromRGB(25, 12, 3)
    btn.TextColor3 = Color3.fromRGB(255, 200, 150)
    btn.Font = Enum.Font.GothamBold
    btn.TextSize = 11
    btn.LayoutOrder = order
    btn.Parent = scrollFrame
    Instance.new("UICorner", btn).CornerRadius = UDim.new(0, 6)
    
    local state = false
    
    local function updateVisual(s)
        state = s
        Enabled[enabledKey] = s
        btn.Text = text .. (key and " [" .. key .. "] " or " ") .. (s and "ON" or "OFF")
        btn.BackgroundColor3 = s and Color3.fromRGB(80, 50, 20) or Color3.fromRGB(25, 12, 3)
        btn.TextColor3 = s and PINK or Color3.fromRGB(255, 200, 150)
        callback(s)
    end
    
    VisualSetters[enabledKey] = updateVisual
    
    btn.MouseButton1Click:Connect(function()
        updateVisual(not state)
    end)
    
    return btn
end

local function createSlider(text, minVal, maxVal, valueKey, callback, order)
    local container = Instance.new("Frame")
    container.Size = UDim2.new(1, -10, 0, 45)
    container.BackgroundColor3 = Color3.fromRGB(25, 12, 3)
    container.LayoutOrder = order
    container.Parent = scrollFrame
    Instance.new("UICorner", container).CornerRadius = UDim.new(0, 6)
    
    local label = Instance.new("TextLabel")
    label.Size = UDim2.new(1, -10, 0, 18)
    label.Position = UDim2.new(0, 5, 0, 2)
    label.Text = text .. ": " .. tostring(Values[valueKey])
    label.TextColor3 = Color3.fromRGB(255, 200, 150)
    label.BackgroundTransparency = 1
    label.Font = Enum.Font.GothamBold
    label.TextSize = 10
    label.TextXAlignment = Enum.TextXAlignment.Left
    label.Parent = container
    
    local sliderBg = Instance.new("Frame")
    sliderBg.Size = UDim2.new(1, -20, 0, 4)
    sliderBg.Position = UDim2.new(0, 10, 0, 28)
    sliderBg.BackgroundColor3 = Color3.fromRGB(45, 25, 10)
    sliderBg.Parent = container
    Instance.new("UICorner", sliderBg).CornerRadius = UDim.new(1, 0)
    
    local pct = (Values[valueKey] - minVal) / (maxVal - minVal)
    local fill = Instance.new("Frame")
    fill.Size = UDim2.new(pct, 0, 1, 0)
    fill.BackgroundColor3 = PINK
    fill.Parent = sliderBg
    Instance.new("UICorner", fill).CornerRadius = UDim.new(1, 0)
    
    local knob = Instance.new("TextButton")
    knob.Size = UDim2.new(0, 12, 0, 12)
    knob.Position = UDim2.new(pct, -6, 0.5, -6)
    knob.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
    knob.Text = ""
    knob.Parent = sliderBg
    Instance.new("UICorner", knob).CornerRadius = UDim.new(1, 0)
    
    local dragging = false
    
    local function updateValue(inputPos)
        local rel = math.clamp((inputPos - sliderBg.AbsolutePosition.X) / sliderBg.AbsoluteSize.X, 0, 1)
        fill.Size = UDim2.new(rel, 0, 1, 0)
        knob.Position = UDim2.new(rel, -6, 0.5, -6)
        local val = math.floor(minVal + (maxVal - minVal) * rel)
        Values[valueKey] = val
        label.Text = text .. ": " .. tostring(val)
        callback(val)
    end
    
    knob.MouseButton1Down:Connect(function()
        dragging = true
        local conn
        conn = UserInputService.InputChanged:Connect(function(input)
            if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
                updateValue(input.Position.X)
            end
        end)
        UserInputService.InputEnded:Connect(function(input)
            if input.UserInputType == Enum.UserInputType.MouseButton1 then
                dragging = false
                conn:Disconnect()
            end
        end)
    end)
    
    return container
end

