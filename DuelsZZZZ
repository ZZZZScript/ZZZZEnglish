-- ============================================================
-- FLOAT
-- ============================================================
local floatConn = nil

local function startFloat()
    if floatConn then return end
    floatConn = RunService.Heartbeat:Connect(function()
        if not Enabled.Float then return end
        local c = Player.Character
        if not c then return end
        local h = c:FindFirstChild("HumanoidRootPart")
        if not h then return end
        local hum = c:FindFirstChildOfClass("Humanoid")
        local moveDir = hum and hum.MoveDirection or Vector3.zero
        
        local currentY = h.Position.Y
        local targetY = 8
        local vertVel = math.clamp((targetY - currentY) * 3, -10, 10)
        
        local horizX = moveDir.Magnitude > 0.1 and moveDir.X * Values.BoostSpeed or 0
        local horizZ = moveDir.Magnitude > 0.1 and moveDir.Z * Values.BoostSpeed or 0
        h.AssemblyLinearVelocity = Vector3.new(horizX, vertVel, horizZ)
    end)
end

local function stopFloat()
    if floatConn then 
        floatConn:Disconnect() 
        floatConn = nil 
    end
end

-- ============================================================
-- UNWALK
-- ============================================================
local savedAnimations = {}

local function startUnwalk()
    local c = Player.Character
    if not c then return end
    local hum = c:FindFirstChildOfClass("Humanoid")
    if hum then 
        for _, t in ipairs(hum:GetPlayingAnimationTracks()) do 
            t:Stop() 
        end
    end
    local anim = c:FindFirstChild("Animate")
    if anim then 
        savedAnimations.Animate = anim:Clone() 
        anim:Destroy() 
    end
end

local function stopUnwalk()
    local c = Player.Character
    if c and savedAnimations.Animate and not c:FindFirstChild("Animate") then
        savedAnimations.Animate:Clone().Parent = c
        savedAnimations.Animate = nil
    end
end

-- ============================================================
-- AUTO STEAL (COM 2 SEGUNDOS)
-- ============================================================
local ProgressBarFill = nil
local ProgressLabel = nil
local ProgressPercentLabel = nil

local function findNearestPrompt()
    local h = Player.Character and Player.Character:FindFirstChild("HumanoidRootPart")
    if not h then return nil end
    
    local plots = Workspace:FindFirstChild("Plots")
    if not plots then return nil end
    
    local np, nd = nil, math.huge
    for _, plot in ipairs(plots:GetChildren()) do
        local podiums = plot:FindFirstChild("AnimalPodiums")
        if podiums then
            for _, pod in ipairs(podiums:GetChildren()) do
                local base = pod:FindFirstChild("Base")
                local spawn = base and base:FindFirstChild("Spawn")
                if spawn then
                    local dist = (spawn.Position - h.Position).Magnitude
                    if dist < nd and dist <= Values.STEAL_RADIUS then
                        local att = spawn:FindFirstChild("PromptAttachment")
                        if att then
                            for _, ch in ipairs(att:GetChildren()) do
                                if ch:IsA("ProximityPrompt") then
                                    np, nd = ch, dist
                                    break
                                end
                            end
                        end
                    end
                end
            end
        end
    end
    return np
end

local function executeSteal(prompt)
    if isStealing then return end
    isStealing = true
    
    if ProgressLabel then 
        ProgressLabel.Text = "STEALING..." 
    end
    
    pcall(function()
        prompt:InputHoldBegin()
        task.wait(Values.STEAL_DURATION)
        prompt:InputHoldEnd()
        prompt:InputEnd()
    end)
    
    if ProgressLabel then 
        ProgressLabel.Text = "READY" 
    end
    if ProgressBarFill then 
        ProgressBarFill.Size = UDim2.new(0, 0, 1, 0) 
    end
    isStealing = false
end

local function startAutoSteal()
    if Connections.autoSteal then return end
    Connections.autoSteal = RunService.Heartbeat:Connect(function()
        if not Enabled.AutoSteal or isStealing then return end
        local p = findNearestPrompt()
        if p then 
            executeSteal(p) 
        end
    end)
end

local function stopAutoSteal()
    if Connections.autoSteal then 
        Connections.autoSteal:Disconnect() 
        Connections.autoSteal = nil 
    end
    isStealing = false
end

-- ============================================================
-- BAT AIMBOT
-- ============================================================
local function startBatAimbot()
    if Connections.batAimbot then return end
    Connections.batAimbot = RunService.Heartbeat:Connect(function()
        if not Enabled.BatAimbot then return end
        local c = Player.Character
        if not c then return end
        local h = c:FindFirstChild("HumanoidRootPart")
        if not h then return end
        
        local nearest, nearestDist = nil, math.huge
        for _, p in ipairs(Players:GetPlayers()) do
            if p ~= Player and p.Character then
                local enemy = p.Character:FindFirstChild("HumanoidRootPart")
                if enemy then
                    local d = (enemy.Position - h.Position).Magnitude
                    if d < nearestDist then
                        nearestDist = d
                        nearest = enemy
                    end
                end
            end
        end
        
        if nearest and nearestDist < 10 then
            local dir = (nearest.Position - h.Position).Unit
            h.AssemblyLinearVelocity = Vector3.new(dir.X * Values.BatAimbotSpeed, h.AssemblyLinearVelocity.Y, dir.Z * Values.BatAimbotSpeed)
            
            local bat = findBat()
            if bat then
                pcall(function() bat:Activate() end)
            end
        end
    end)
end

local function stopBatAimbot()
    if Connections.batAimbot then
        Connections.batAimbot:Disconnect()
        Connections.batAimbot = nil
    end
end

