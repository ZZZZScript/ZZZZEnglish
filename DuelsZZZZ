-- ============================================================
-- FUNÇÕES DO MENU
-- ============================================================
local menuVisible = true

chBtn.MouseButton1Click:Connect(function()
    menuVisible = not menuVisible
    MainContainer.Visible = menuVisible
end)

closeBtn.MouseButton1Click:Connect(function()
    MainContainer.Visible = false
    menuVisible = false
end)

-- Arrastar ícone
local dragging = false
local dragStart, startPos

chBtn.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 then
        dragging = true
        dragStart = input.Position
        startPos = chCircle.Position
    end
end)

chBtn.InputEnded:Connect(function()
    dragging = false
end)

UserInputService.InputChanged:Connect(function(input)
    if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
        local delta = input.Position - dragStart
        chCircle.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
    end
end)

-- Arrastar menu
local menuDrag = false
local menuDragStart, menuStartPos

titleBar.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 then
        menuDrag = true
        menuDragStart = input.Position
        menuStartPos = MainContainer.Position
    end
end)

titleBar.InputEnded:Connect(function()
    menuDrag = false
end)

UserInputService.InputChanged:Connect(function(input)
    if menuDrag and input.UserInputType == Enum.UserInputType.MouseMovement then
        local delta = input.Position - menuDragStart
        MainContainer.Position = UDim2.new(menuStartPos.X.Scale, menuStartPos.X.Offset + delta.X, menuStartPos.Y.Scale, menuStartPos.Y.Offset + delta.Y)
    end
end)

-- ============================================================
-- KEYBINDS
-- ============================================================
UserInputService.InputBegan:Connect(function(input, gpe)
    if gpe then return end
    
    if input.KeyCode == Enum.KeyCode.Delete then
        ScreenGui:Destroy()
    elseif input.KeyCode == Enum.KeyCode.U then
        menuVisible = not menuVisible
        MainContainer.Visible = menuVisible
    elseif input.KeyCode == KEYBINDS.SPEED then
        local newState = not Enabled.SpeedBoost
        if VisualSetters.SpeedBoost then VisualSetters.SpeedBoost(newState) end
    elseif input.KeyCode == KEYBINDS.FLOAT then
        local newState = not Enabled.Float
        if VisualSetters.Float then VisualSetters.Float(newState) end
    elseif input.KeyCode == KEYBINDS.BATAIMBOT then
        local newState = not Enabled.BatAimbot
        if VisualSetters.BatAimbot then VisualSetters.BatAimbot(newState) end
    end
end)

